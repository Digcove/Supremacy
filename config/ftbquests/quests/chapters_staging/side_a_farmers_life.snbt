			item: {id: "pamhc2crops:oatitem", Count: 8b}
		}]
	}, {
		id: "0000000000013030"
		x: 4.0d
		y: 32.0d
		dependencies: ["0000000000013010"]
		title: "A Pinch of Salt"
		icon: {id: "pamhc2foodcore:saltitem", Count: 1b}
		description: ["Salt is extracted by boiling water in the Pot. One Pot with a water bottle or bucket yields one salt — simple, but salt appears in nearly every savory recipe: cheese, dough, stew, mashed potatoes, crackers. Keep a stack on hand.", "You will burn through it faster than expected once cooking ramps up. Glass bottles filled from any water source work. If your base is near a river or ocean this is essentially free, and any water bottle in your inventory can become salt in one crafting operation."]
		tasks: [{
			id: "0000000000013031"
			type: "item"
			item: {id: "pamhc2foodcore:saltitem", Count: 1b}
			count: 4L
		}]
		rewards: [{
			id: "0000000000013032"
			type: "item"
			item: {id: "minecraft:glass_bottle", Count: 8b}
		}]
	}, {
		id: "0000000000013040"
		x: 6.0d
		y: 32.0d
		dependencies: ["0000000000013010"]
		title: "Pressed Oil"
		icon: {id: "pamhc2foodcore:cookingoilitem", Count: 1b}
		description: ["Cooking Oil is pressed from nuts using the Roller. Any nut from Pam's tree crops — peanuts, almonds, chestnuts — can be rolled into oil, producing two bottles per use. Oil is the frying medium for fried chicken and a required ingredient in several other savory dishes.", "Peanut is a ground crop that grows in Botany Pots, making it the easiest source of a fully automated oil supply. If your almond or chestnut trees are already mature, roll the surplus. Two nuts, two bottles — it adds up fast."]
		tasks: [{
			id: "0000000000013041"
			type: "item"
			item: {id: "pamhc2foodcore:cookingoilitem", Count: 1b}
			count: 4L
		}]
