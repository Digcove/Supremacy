	quests: [{
		id: "0000000000005001"
		x: 0.0d
		y: 0.0d
		title: "Two Worlds, One Craft"
		icon: {id: "minecraft:nether_star", Count: 1b}
		description: ["The Orb Forge is where combat mastery and industrial power collide. Every currency you craft here demands two things: a Mine & Slash Salvage Stone gate that proves you can survive, and a GregTech machine component that proves you can build.", "Six tier stations. One culminating machine. The tier stations unlock throughout your progression — Tiers 1 through 3 are accessible from Medium Voltage onward, Tier 4 follows ZPM, Tier 5 follows UHV. Each station can produce its orbs whenever you build it, though more slowly than the machine that waits at the end of this chapter.", "The Orb Forge itself runs every recipe in the system at four times the speed of the individual stations. It is not a replacement — the stations stay active and usable. It is the reward for completing everything before it. Start with a Common Salvage Stone and a Low Voltage circuit. The rest follows."]
		tasks: [{
			id: "0000000000005002"
			type: "item"
			item: {id: "mmorpg:stone/0", Count: 1b}
		}]
		rewards: []
	}, {
		id: "0000000000005003"
		x: 2.0d
		y: 0.0d
		dependencies: ["0000000000005001"]
		title: "Tier 1 — Basic Modify Station"
		icon: {id: "mmorpg:stone/0", Count: 1b}
		description: ["Build the Basic Modify Station using the Multiblocked2 Machine Editor. This machine runs on Low Voltage (LV) and accepts Common Salvage Stones as its combat gate.", "Once assembled and formed, it can produce Scrolls of Wisdom, Portal Scrolls, and Orbs of Transmutation — the three essentials of early gear crafting. It is the slowest station in the system. The Orb Forge runs all of its recipes in 25 ticks. The Basic Modify Station takes 100. Same inputs, four times the wait. Build it early. Replace it eventually."]
		tasks: [{
