			}]
			title: "HV Chemical Reactor"
			x: -6.0d
			y: -2.0d
		}
		{
			dependencies: ["8C8D0004EEFF0004"]
			description: ["The Arc Furnace smelts conductive metals using an electric arc rather than resistive heating — it processes Iron, Steel, and alloy scraps into high-quality ingots with zero fuel cost and no temperature ceiling. It is the primary source of Wrought Iron at HV volume, and also accepts salvaged machine components and ore dust that the EBF would waste. Build one immediately and route all metallic waste streams through it; the Arc Furnace is among the most EU-efficient machines in GTCEu when processing scrap."]
			id: "8C8D0006EEFF0006"
			rewards: [{
				count: 5
				id: "9D9E0006FFAA0001"
				item: "kubejs:coin"
				type: "item"
			}]
