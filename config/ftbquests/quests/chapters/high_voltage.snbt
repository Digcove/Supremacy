		{
			dependencies: [
				"8C8D0001EEFF0001"
				"8C8D0002EEFF0002"
			]
			description: ["The HV Machine Hull requires Stainless Steel Plates and a Twilight Lich Trophy in addition to the standard hull structure. The Trophy acts as a high-frequency resonance stabilizer embedded in the hull bus — without one, the hull cannot maintain medium-to-high voltage differential across the machine casing under load. Unlike the LV and MV hulls, the HV Hull is significantly more material-intensive; build your Stainless Steel reserves before starting the assembly line."]
			id: "8C8D0003EEFF0003"
			rewards: [{
				count: 6
				id: "9D9E0003FFAA0001"
				item: "kubejs:coin"
				type: "item"
			}]
			shape: "gear"
			size: 1.5d
			tasks: [{
				id: "AAAB0003BBCC0001"
				item: "gtceu:hv_machine_hull"
				type: "item"
			}]
			title: "HV Machine Hull"
			x: -8.0d
			y: 0.0d
		}
		{
			dependencies: ["8C8D0003EEFF0003"]
			description: ["The HV Electric Motor is the core component of all HV machines. Its higher coil density and current rating enables the power draw that HV-tier multiblocks require. Build several before beginning the HV machine floor — the component cascade for a full HV suite is substantial. The HV Pump, HV Robot Arm, HV Conveyor, and HV Piston all share this motor as a base, and several are also required for the machines themselves as subcomponents."]
			id: "8C8D0004EEFF0004"
			rewards: [{
				count: 4
				id: "9D9E0004FFAA0001"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [{
				id: "AAAB0004BBCC0001"
				item: "gtceu:hv_electric_motor"
				type: "item"
			}]
			title: "HV Motor"
			x: -6.0d
			y: 0.0d
		}
		{
			dependencies: ["8C8D0004EEFF0004"]
			description: ["The HV Chemical Reactor handles chemistry at high voltage — faster cycle times, wider fluid input range, and access to reactions that lower-tier reactors cannot sustain thermally. At this tier it enables Platinum Group Metal separation, advanced polymer production, and Titanium Tetrachloride processing for refined Titanium output. Route your Sulfuric Acid, Hydrochloric Acid, and Sodium Persulfate production through HV reactors as soon as they are assembled; the throughput difference over MV is significant at the volumes HV demands."]
			id: "8C8D0005EEFF0005"
			optional: true
			rewards: [{
				count: 3
				id: "9D9E0005FFAA0001"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [{
				id: "AAAB0005BBCC0001"
