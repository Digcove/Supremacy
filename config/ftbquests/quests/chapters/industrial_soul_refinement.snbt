	quests: [
		{
			dependencies: [
				"3B495C6068F785CD"
				"41BDD2ED2D884E3C"
			]
			description: ["Create's Crushing Wheels process raw ores into crushed ore chunks, guaranteeing two outputs per ore — a full 2x yield with no RNG. Place two counter-rotating wheels with a single-block gap between them and drop ore into the gap. Both wheels require rotational input; connect them via shaft to any power source. Speed determines throughput, not yield — even a slow Water Wheel is sufficient to begin."]
			id: "682F366436809BCC"
			rewards: [{
				count: 3
				id: "0A8F2B4C6D1E3F50"
				item: "lightmanscurrency:coin_gold"
				type: "item"
			}]
			tasks: [{
				count: 2L
				id: "5F3F998A44F465FB"
				item: "create:crushing_wheel"
				type: "item"
			}]
			title: "Crushing Wheels"
			x: 4.0d
			y: -5.0d
		}
		{
			dependencies: [
				"682F366436809BCC"
				"1360F2689830BE48"
			]
			description: ["Fan Ore Washing adds a secondary output on top of your Crushing Wheels yield. Build a column of water source blocks, then drive an Encased Fan to push air horizontally through them. Crushed ore passing through exits as Washed Crushed Ore, yielding a bonus purified ore item on top of the base crush output. The fan requires rotational input; any Water Wheel connection is sufficient."]
			id: "4CCA4B2A9DAE30AE"
			rewards: [{
				count: 3
				id: "1B9A3C5D7E2F4A61"
				item: "lightmanscurrency:coin_gold"
				type: "item"
			}]
			tasks: [{
				id: "6527E6ADFC09EC3B"
				item: "create:encased_fan"
				type: "item"
			}]
			title: "Fan Ore Washing"
			x: 8.0d
			y: -4.5d
		}
		{
			dependencies: ["682F366436809BCC"]
			description: ["Create's crushing recipes yield more than just ore. Gravel produces Flint. Blaze Rods give Blaze Powder with a chance at Blaze Mesh. Many ores have secondary dust outputs — Iron has a chance at Manganese, Gold yields a chance at Copper Dust. Route your output belt through a Brass Funnel set to filter so crushed ore and byproducts sort into separate chests automatically. At scale, these compounds into real value."]
			id: "2E5F7A9B1C3D6E82"
			optional: true
			rewards: [{
				count: 2
				id: "6A8C1E3F5B7D9A24"
