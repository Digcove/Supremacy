				type: "item"
			}]
			title: "LV Mixer"
			x: 52.0d
			y: -2.0d
		}
		{
			dependencies: ["20078A3EE4C9425E"]
			description: ["The LV Chemical Reactor is GT's primary fluid chemistry machine — it combines fluid and item inputs to produce reagents, solutions, and byproduct gases. At LV tier it handles Sodium Persulfate for PCB etching, Sulfuric Acid for ore leaching, and Hydrogen via electrolysis chains. The Chemical Reactor unlocks GT's chemical tree, which runs in parallel with the ore processing chain from MV onward. Build it before you need it — reagent supply is always the bottleneck, never the machine."]
			id: "2BAC972B6424A2AB"
			optional: true
			rewards: [{
				count: 2
				id: "12340000AABB0011"
