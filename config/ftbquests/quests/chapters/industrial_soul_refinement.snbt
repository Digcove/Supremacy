			x: 64.0d
			y: 1.0d
		}
		{
			dependencies: [
				"5A5B0006CCDD0006"
				"5A5B0009CCDD0009"
			]
			description: ["The MV Machine Hull requires Aluminium Plates, Aluminium Machine Casings, and an Epic-quality Mine & Slash Power Stone — a gemstone of sufficient soul resonance to stabilize medium-voltage current through the hull's internal bus. Epic Power Stones drop from Elite and Champion M&S enemies in zones scaled to your current rank; they are not found at low-tier encounter difficulty. Secure one, then assemble the hull. Every MV machine depends on this component as its chassis."]
			id: "5A5B000ACCDD000A"
