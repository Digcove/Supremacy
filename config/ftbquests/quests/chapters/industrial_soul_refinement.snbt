				type: "item"
			}]
			title: "LV Alloy Smelter"
			x: 50.0d
			y: -2.0d
		}
		{
			dependencies: ["43CBA3E6F9CF363F"]
			description: ["The LV Mixer combines two to four input items into alloy outputs or compound dusts. Unlike the Alloy Smelter it accepts fluids and wet compounds — Concrete, Slurry, Electrolyte solutions, and several chemical intermediates are Mixer-exclusive recipes. For alloy production the Mixer is slightly slower than the Alloy Smelter but accepts a broader range of input forms. Build it alongside rather than instead of the Alloy Smelter."]
			id: "35DC7C5EBC1EC6AA"
			optional: true
			rewards: [{
				count: 2
				id: "12340000AABB0010"
				item: "lightmanscurrency:coin_gold"
