				type: "item"
			}]
			tasks: [{
				id: "4F2A6B8C1D3E5F73"
				title: "Crushing Byproducts"
				type: "checkmark"
			}]
			title: "Crushing Byproducts"
			x: 5.5d
			y: -6.5d
		}
		{
			dependencies: [
				"682F366436809BCC"
				"0FCDD275FC93F23B"
				"6CD3FDD027906C44"
			]
			description: ["The Orechid is a Botania generating flower that transmutes adjacent Stone blocks into random ores over time, consuming 17,500 mana per conversion. It is crafted at the Petal Apothecary using Polished Rose Quartz — a material that only exists because of Create's sandpaper mechanic. This is the first hard convergence point between mechanical and magical systems. Plant it underground near dense Stone, fed by a dedicated Mana Spreader and Pool. A bank of four Orechids provides meaningful passive ore supplementation without ever lifting a pickaxe."]
			id: "5A3B7C9D1E2F4A65"
			optional: true
			rewards: [{
				count: 4
				id: "2F4A6B8C1D3E5F78"
