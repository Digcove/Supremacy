			type: "item"
			item: {id: "gtceu:iron_dust", Count: 16b}
		}]
	}, {
		id: "000000000000F00A"
		x: 6.0d
		y: 0.0d
		dependencies: ["000000000000F007"]
		title: "The Naga"
		icon: {id: "twilightforest:naga_scale", Count: 1b}
		description: ["The Twilight Forest Naga is a serpentine boss that circles its arena endlessly. It has no ranged attack — just speed, mass, and the ability to break through any wall you hide behind. Fight in the open.", "It drops Naga Scales on death. You need four of them. This is the combat gate for the Electric Blast Furnace — you cannot build GregTech's EBF without killing this boss first."]
		tasks: [{
			id: "000000000000F00B"
			type: "item"
			item: {id: "twilightforest:naga_scale", Count: 4b}
		}]
		rewards: [{
			id: "000000000000F00C"
