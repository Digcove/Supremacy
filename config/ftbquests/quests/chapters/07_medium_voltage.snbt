			item: {id: "twilightforest:naga_scale", Count: 4b}
		}]
	}, {
		id: "000000000000F00D"
		x: 8.0d
		y: 0.0d
		dependencies: ["000000000000F00A"]
		title: "The Coil"
		icon: {id: "gtceu:cupronickel_coil_block", Count: 1b}
		description: ["The Cupronickel Coil Block is what the Electric Blast Furnace is built from. It generates the heat. Without Naga Scales woven into the coil structure, the recipe doesn't complete — the serpent's material conducts heat in a way nothing else does.", "Craft the Coil Blocks. You need at least two to build the EBF multiblock."]
		tasks: [{
