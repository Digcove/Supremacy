		id: "000000000000F010"
		x: 10.0d
		y: 0.0d
		dependencies: ["000000000000F00D"]
		title: "Electric Blast Furnace"
		icon: {id: "gtceu:electric_blast_furnace", Count: 1b}
		description: ["The EBF is a 3x3x4 multiblock — a steel casing shell with Cupronickel Coil Blocks on the inner ring. It smelts materials at temperatures that no normal furnace can reach: aluminium, titanium, and every alloy above steel.", "Build it. This is the gate between LV and MV. Nothing past this point is accessible without it."]
		tasks: [{
			id: "000000000000F011"
