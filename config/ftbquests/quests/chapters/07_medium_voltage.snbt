		}]
	}, {
		id: "000000000000F004"
		x: 2.0d
		y: 0.0d
		dependencies: ["000000000000F001"]
		title: "First Power"
		icon: {id: "gtceu:lv_battery_buffer_4a", Count: 1b}
		description: ["GregTech machines run on EU — Energy Units. A Steam Turbine or LV Dynamo from GregTech generates it. A Battery Buffer stores it and distributes to machines on the same cable network.", "Wire everything together. If a machine isn't getting power, check the cable tier — LV cable carries LV current. MV cable carries more. Don't mix them without a transformer."]
		tasks: [{
			id: "000000000000F005"
			type: "checkmark"
			title: "Power a GregTech LV machine from a generator via cable"
		}]
		rewards: [{
			id: "000000000000F006"
			type: "item"
			item: {id: "gtceu:tin_single_cable", Count: 32b}
		}]
	}, {
		id: "000000000000F007"
		x: 4.0d
		y: 0.0d
		dependencies: ["000000000000F004"]
		title: "The Macerator"
		icon: {id: "gtceu:lv_macerator", Count: 1b}
		description: ["The LV Macerator is your first real ore processor. It doubles ore output by crushing raw ore into two dust piles — smelt the dust for two ingots per ore. This replaces the Create Millstone for GregTech-native ores.", "Run every ore through here. The Macerator also produces useful byproduct dusts that feed into other GregTech recipes."]
		tasks: [{
			id: "000000000000F008"
			type: "item"
			item: {id: "gtceu:lv_macerator", Count: 1b}
		}]
		rewards: [{
