	quests: [{
		id: "0000000000006001"
		x: 0.0d
		y: 0.0d
		title: "Out of the Stone Age"
		icon: {id: "minecraft:iron_ingot", Count: 1b}
		description: ["Flint and bone got you here. Iron will take you further. Smelt your first iron ingots — dig deep, find a cave, find the ore. The surface veins go fast.", "You'll need a lot of iron. Start now."]
		tasks: [{
			id: "0000000000006002"
			type: "item"
			item: {id: "minecraft:iron_ingot", Count: 1b}
			count: 8L
		}]
		rewards: [{
			id: "0000000000006003"
			type: "item"
			item: {id: "minecraft:furnace", Count: 1b}
		}]
	}, {
		id: "0000000000006004"
		x: 2.0d
		y: 0.0d
		dependencies: ["0000000000006001"]
		title: "The Tinker's Workshop"
		icon: {id: "tconstruct:smeltery_controller", Count: 1b}
		description: ["Tinkers' Construct throws out the crafting table for making tools. Instead: a Smeltery, Casting Tables, and Part Builders. Every material has different traits. Iron tools are just the beginning — bronze, cobalt, and stranger things wait.", "Build the Smeltery Controller and surround it with Seared Bricks to form the Smeltery structure. It needs at least one Drain and a Tank to hold liquid metal."]
		tasks: [{
			id: "0000000000006005"
			type: "item"
			item: {id: "tconstruct:smeltery_controller", Count: 1b}
		}]
		rewards: [{
			id: "0000000000006006"
			type: "item"
			item: {id: "minecraft:iron_ingot", Count: 4b}
		}, {
			id: "0000000000006007"
			type: "item"
			item: {id: "tconstruct:grout", Count: 16b}
		}]
	}, {
		id: "0000000000006008"
		x: 4.0d
		y: -1.0d
		dependencies: ["0000000000006004"]
		title: "First Cast"
		icon: {id: "tconstruct:pickaxe", Count: 1b}
		description: ["Pour molten iron into a Pickaxe Head Cast. Pull it from the table. Bind it to a tool rod on the Tool Station.", "A Tinkers' pickaxe mined wrong is still faster than a vanilla one. A Tinkers' pickaxe built right lasts forever and grows stronger with use."]
		tasks: [{
			id: "0000000000006009"
			type: "item"
			item: {id: "tconstruct:pickaxe", Count: 1b}
		}]
		rewards: [{
			id: "000000000000600A"
			type: "item"
			item: {id: "minecraft:iron_ingot", Count: 8b}
		}]
	}, {
		id: "000000000000600B"
		x: 4.0d
		y: 1.0d
		dependencies: ["0000000000006001"]
		title: "Cogs and Shafts"
		icon: {id: "create:cogwheel", Count: 1b}
		description: ["Create doesn't run on electricity or magic — it runs on rotational force. Cogwheels carry that rotation from a source to a machine. Start here.", "Almost everything in Create chains off this. A Shaft carries rotation, a Cogwheel transfers it, and a Gearbox changes direction. Learn this language — you'll be speaking it for a long time."]
		tasks: [{
			id: "000000000000600C"
			type: "item"
			item: {id: "create:cogwheel", Count: 1b}
			count: 4L
		}]
		rewards: [{
			id: "000000000000600D"
			type: "item"
			item: {id: "create:shaft", Count: 4b}
		}]
	}, {
		id: "000000000000600E"
		x: 6.0d
		y: 1.0d
		dependencies: ["000000000000600B"]
		title: "Water Power"
		icon: {id: "create:water_wheel", Count: 1b}
		description: ["No fuel. No magic. Just a river and patience.", "Place a Water Wheel in flowing water — it needs water moving on at least one side. Connect it via Shaft to your machine network. It's your first free power source, and it won't let you down."]
		tasks: [{
			id: "000000000000600F"
			type: "item"
			item: {id: "create:water_wheel", Count: 1b}
		}]
		rewards: [{
			id: "0000000000006010"
			type: "item"
			item: {id: "create:shaft", Count: 8b}
		}]
	}, {
		id: "0000000000006011"
		x: 8.0d
		y: 1.0d
		dependencies: ["000000000000600E"]
		title: "Grind It Out"
		icon: {id: "create:millstone", Count: 1b}
		description: ["Put a Millstone above your Water Wheel's rotation and feed it raw ores. It crushes them into Crushed Ore — smelt that and you get two ingots per ore instead of one.", "This is your first ore doubling. It won't be your last. Don't smelt raw ore ever again."]
		tasks: [{
			id: "0000000000006012"
			type: "item"
			item: {id: "create:millstone", Count: 1b}
		}]
		rewards: [{
			id: "0000000000006013"
			type: "item"
			item: {id: "minecraft:iron_ingot", Count: 16b}
		}]
	}, {
		id: "0000000000006014"
		x: 6.0d
		y: -1.0d
		dependencies: ["0000000000006004"]
		title: "Silent Blueprints"
		icon: {id: "silentgear:blueprint_package", Count: 1b}
		description: ["Silent Gear takes a different approach from Tinkers': parts are printed from blueprints, then crafted from materials. The Blueprint Package gets you started — right-click to unpack the starter templates.", "Silent Gear tools can be repaired, modified mid-use, and built from dozens of materials. It runs parallel to Tinkers' — try both, use what fits your playstyle."]
		tasks: [{
			id: "0000000000006015"
			type: "item"
			item: {id: "silentgear:blueprint_package", Count: 1b}
		}]
		rewards: [{
