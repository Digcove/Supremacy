		}]
	}, {
		id: "0000000000006027"
		x: 14.0d
		y: 2.0d
		dependencies: ["0000000000006024"]
		title: "Fan Service"
		icon: {id: "create:encased_fan", Count: 1b}
		description: ["An Encased Fan pointed at a fire source blows a column of hot air. Items on a Belt passing through that air get auto-smelted. Point it at water and they get washed — Crushed Ore becomes Purified Ore, tripling your yield from raw ore to ingot.", "Set up a wash line. Never smelt raw ore by hand again."]
		tasks: [{
			id: "0000000000006028"
			type: "item"
			item: {id: "create:encased_fan", Count: 1b}
		}]
		rewards: [{
			id: "0000000000006029"
			type: "item"
			item: {id: "create:andesite_alloy", Count: 16b}
		}]
	}, {
		id: "000000000000602A"
		x: 16.0d
		y: 2.0d
		dependencies: ["0000000000006027"]
		title: "The Brass Age"
		icon: {id: "create:brass_ingot", Count: 1b}
		description: ["Feed your heated Basin copper and zinc. The result is Brass — Create's primary alloy. Brass unlocks the intelligent half of Create's machine line: Mechanical Arms that move items between machines, Sequenced Gearshifts that control timing, Smart Chutes that filter. You've moved from moving things to directing things."]
		tasks: [{
			id: "000000000000602B"
			type: "item"
			item: {id: "create:brass_ingot", Count: 1b}
			count: 8L
		}]
		rewards: [{
			id: "000000000000602C"
			type: "item"
			item: {id: "create:brass_cogwheel", Count: 4b}
		}, {
			id: "000000000000602D"
