		}]
	}, {
		id: "0000000000006021"
		x: 10.0d
		y: 2.0d
		dependencies: ["0000000000006011"]
		title: "Basin Basics"
		icon: {id: "create:basin", Count: 1b}
		description: ["The Basin sits below a rotation source and above a heat source. Drop items in, pipe in fluids, and it mixes, heats, or cools them. Most of Create's advanced materials start here — Brass, Rose Quartz, Chromatic Compound. Build one.", "Every Create automation line that does more than move items passes through this block."]
		tasks: [{
			id: "0000000000006022"
			type: "item"
			item: {id: "create:basin", Count: 1b}
		}]
		rewards: [{
			id: "0000000000006023"
			type: "item"
			item: {id: "create:blaze_cake", Count: 4b}
		}]
	}, {
		id: "0000000000006024"
		x: 12.0d
		y: 2.0d
		dependencies: ["0000000000006021"]
		title: "Burn Bright"
		icon: {id: "create:blaze_burner", Count: 1b}
		description: ["Place a Blaze Burner under your Basin. Right-click it with a Blaze Cake to ignite it — it runs indefinitely on one cake. Once lit, it unlocks heated Basin recipes. Without heat, you can mix. With heat, you can alloy."]
		tasks: [{
			id: "0000000000006025"
			type: "item"
			item: {id: "create:blaze_burner", Count: 1b}
		}]
		rewards: [{
