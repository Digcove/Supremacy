		id: "0000000000006017"
		x: 8.0d
		y: -1.0d
		dependencies: ["0000000000006014"]
		title: "The Plating Press"
		icon: {id: "create:mechanical_press", Count: 1b}
		description: ["The Mechanical Press turns ingots into plates and sheets — outputs that Silent Gear parts need, and that many other recipes require. Mount it above a Rotation Source and drop items onto the Belt below.", "Create and Silent Gear feed each other. This press will see heavy use."]
		tasks: [{
			id: "0000000000006018"
			type: "item"
			item: {id: "create:mechanical_press", Count: 1b}
		}]
		rewards: [{
			id: "0000000000006019"
			type: "item"
			item: {id: "create:andesite_alloy", Count: 8b}
		}]
	}, {
		id: "000000000000601E"
		x: 2.0d
		y: -3.0d
		title: "The Spirit Vein"
		icon: {id: "soulland:spirit_iron_ore", Count: 1b}
		description: ["Spirit Iron Ore spawns in the same depth bands as regular iron but with a faint blue-grey shimmer. Your Tinkers' pickaxe will mine it fine. Run it through the Create Millstone for doubled output exactly like vanilla ore.", "Spirit Iron Ingots are the base material for the entire Soul Land crafting line — Forging Table, tools, weapons, armor, pills. Mine it alongside regular iron and keep a separate chest for it. Check the Soul Land side chapter (Side D) for where it goes next."]
		tasks: [{
			id: "000000000000601F"
			type: "item"
			item: {id: "soulland:spirit_iron_ore", Count: 1b}
			count: 8L
