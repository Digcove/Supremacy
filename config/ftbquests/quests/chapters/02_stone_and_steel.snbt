	}, {
		id: "000000000000601A"
		x: 10.0d
		y: 0.0d
		dependencies: ["0000000000006011", "0000000000006008"]
		title: "Uncommon Ground"
		icon: {id: "mmorpg:stone/1", Count: 1b}
		description: ["By now you should be killing enough enemies that you have a steady supply of Uncommon-quality M&S gear drops. Don't leave it on the ground — take it to the Salvage Table to break it into Salvage Stones. The Mine & Slash Backpack also has an auto-salvage feature that handles this automatically.", "Stone rarity matches the gear you consume: Uncommon gear → Uncommon Stone (stone/1). These are the combat gate for Tier 2 of the Orb Forge. Salvage everything you don't equip. Check the Steel & Glory side chapter for the full salvage and currency system."]
		tasks: [{
			id: "000000000000601B"
			type: "item"
			item: {id: "mmorpg:stone/1", Count: 1b}
			count: 3L
		}]
		rewards: [{
