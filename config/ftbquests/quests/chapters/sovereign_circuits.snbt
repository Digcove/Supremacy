		{
			dependencies: [
				"IV0100000000000E"
				"IV01000000000008"
			]
			description: ["The Power Substation is GTCEu's largest energy buffer — a multiblock structure capable of storing hundreds of billions of EU across tiered Laser Hatch connections. It acts as the central battery for your IV and LuV power network, smoothing out the demand spikes of EBF alloy runs, Assembly Line production cycles, and Fusion Reactor startup draws. Build it before the LuV Fusion Reactor — the Reactor's startup sequence draws a massive EU pulse, and you need the buffer to absorb it."]
			id: "IV0100000000000F"
