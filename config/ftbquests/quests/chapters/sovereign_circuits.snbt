		}
		{
			dependencies: ["IV01000000000004"]
			description: ["The Micro Processor Assembly bundles four Micro Processors into a single component board, used in the Micro Processor Computer and in high-tier machine recipes. At the scale required for IV production lines, automated circuit production via the Circuit Assembler multiblock is no longer optional — batch producing Assemblies manually will consume more time than it saves. Wire your Circuit Assembler into your AE2 autocrafting network and request on demand."]
			id: "IV01000000000005"
