			title: "Sovereign Circuits"
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["IV01000000000001"]
			description: ["The CPU Wafer is produced in the Chemical Vapor Deposition unit from Silicon Boule sliced to wafers, then etched and cleaned in subsequent GTCEu chemistry steps. The CPU Chip is the first silicon component that cannot be hand-crafted — it requires your integrated GTCEu chemistry pipeline at HV tier, running continuously. Establish wafer fabrication before attempting any IV-tier circuit production. The entire chip ladder above depends on this loop being stable."]
			id: "IV01000000000002"
			rewards: [
				{
					auto: "enabled"
					command: "/mine_and_slash give xp_times_lvl @p 150"
