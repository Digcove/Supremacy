			y: 0.0d
		}
		{
			dependencies: ["IV01000000000002"]
			description: ["The Microchip Processor is the entry-level IV circuit, assembled from CPU Chips and support components in the MV Circuit Assembler. At this scale, circuit fabrication begins to dominate recipe throughput — a single IV machine may require dozens of Microchip Processors before construction can begin. Automate your Circuit Assembler now and keep it running between projects; the demand only increases from here."]
			id: "IV01000000000003"
			rewards: [
				{
					auto: "enabled"
