	quests: [
		{
			dependencies: ["AE01000000000007"]
			description: ["Extreme Voltage was just the beginning. The IV tier represents the first rung of GTCEu's high-voltage endgame — a domain where raw circuit density begins to outpace human-scale assembly. The Micro Processor chip architecture introduces a new wafer fabrication loop, and the Assembly Line replaces the crafting table as your production method for everything that follows. Nothing at this tier opens without proving your magical progression has matched your industrial ambition first. The Elven realm has something to say about that."]
			id: "IV01000000000001"
			rewards: [{
				auto: "enabled"
				command: "/mine_and_slash give xp_times_lvl @p 150"
				elevate_perms: true
				icon: "minecraft:experience_bottle"
