			}]
			title: "Microchip Processor"
			x: 6.0d
			y: 0.0d
		}
		{
			dependencies: ["IV01000000000003"]
			description: ["The Micro Processor is the standard IV-tier circuit, assembled from Microchip Processor and RAM components. It unlocks most standard IV machines. For now, produce it in the HV Circuit Assembler using the available recipe path — the IV Circuit Assembler, which runs it faster and cheaper, requires the Nano Processor Mainframe to build first, and that milestone is a few steps ahead. Stockpile Micro Processors before starting any IV machine builds."]
			id: "IV01000000000004"
			rewards: [
