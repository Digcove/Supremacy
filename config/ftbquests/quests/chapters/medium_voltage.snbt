			tasks: [{
				count: 32L
				id: "6A6B0003CCDD0001"
				item: { Count: 32, id: "gtceu:steel_machine_casing" }
				type: "item"
			}]
			title: "EBF Casings"
			x: -10.0d
			y: 0.0d
		}
		{
			dependencies: [
				"5A5B0003CCDD0003"
				"5A5B0002CCDD0002"
			]
			description: ["The Electric Blast Furnace is a 3×3×4 hollow multiblock: outer walls of Steel Machine Casings, inner ring of Coil Blocks, the EBF Controller on the front face, and Output and Input Hatches for solid and fluid I/O. A Muffler Hatch on one side vents waste heat. Connect EU to the Energy Input Hatch at LV or MV voltage. The EBF does not run on steam — it requires electric current. The first batch of Aluminium at 1700K proves the machine is correctly assembled and the coil ring is complete."]
			id: "5A5B0004CCDD0004"
			rewards: [{
				count: 6
				id: "7A7B0004CCDD0001"
				item: "kubejs:coin"
				type: "item"
			}]
			shape: "gear"
			size: 1.5d
			tasks: [{
				id: "6A6B0004CCDD0001"
				item: "gtceu:electric_blast_furnace"
				type: "item"
			}]
			title: "Electric Blast Furnace"
			x: -8.0d
			y: 0.0d
		}
		{
			dependencies: ["5A5B0004CCDD0004"]
			description: ["Aluminium is smelted from Bauxite ore — process raw Bauxite through the Macerator to obtain Bauxite Dust, then feed it to the EBF at 1700K. Cupronickel coils reach 1801K, comfortably clearing this threshold. Aluminium Ingots are the primary material for the MV Machine Hull, the MV Circuit substrate, and several machine components. Smelt at least 64 before proceeding — demand accelerates rapidly once the MV machine floor comes online and alloy production begins."]
			id: "5A5B0005CCDD0005"
			rewards: [
				{
					count: 3
					id: "7A7B0005CCDD0001"
					item: "kubejs:coin"
					type: "item"
				}
				{
					count: 8
					id: "7A7B0005CCDD0002"
					item: "gtceu:aluminium_ingot"
					type: "item"
				}
			]
			tasks: [{
				count: 8L
				id: "6A6B0005CCDD0001"
				item: { Count: 8, id: "gtceu:aluminium_ingot" }
				type: "item"
			}]
			title: "Aluminium"
			x: -6.0d
			y: 0.0d
		}
		{
			dependencies: ["5A5B0005CCDD0005"]
			description: ["Aluminium Plates are produced by running Aluminium Ingots through the LV Bender — the plate yield from hammer shaping is half the Bender's output at the cost of twice the tool durability. Build nine for the MV Machine Hull and a surplus stockpile for casing and component demand beyond. Plates, not ingots, are the structural raw material of MV construction — convert your entire Aluminium ingot output to plates at the Bender before downstream processes consume it."]
			id: "5A5B0006CCDD0006"
			rewards: [{
				count: 3
				id: "7A7B0006CCDD0001"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [{
				count: 9L
				id: "6A6B0006CCDD0001"
				item: { Count: 9, id: "gtceu:aluminium_plate" }
				type: "item"
			}]
			title: "Aluminium Plates"
			x: -4.0d
			y: 0.0d
		}
		{
			dependencies: ["5A5B0004CCDD0004"]
			description: ["Silicon is produced by processing Quartzite Dust or Silicon Dioxide in the EBF at approximately 1700K — within Cupronickel coil range. Silicon Ingots are then cut by the Wiremill into Silicon Wafers, which are etched and layered into NAND Chips. Silicon is the foundation of every circuit tier above LV and must be produced in continuous quantity; the combined circuit demand from MV machines and the EBF upgrade chain is substantial and begins immediately."]
			id: "5A5B0007CCDD0007"
			rewards: [{
				count: 3
				id: "7A7B0007CCDD0001"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [{
				count: 4L
				id: "6A6B0007CCDD0001"
				item: { Count: 4, id: "gtceu:silicon_ingot" }
				type: "item"
			}]
			title: "Silicon"
			x: -6.0d
			y: -2.0d
		}
		{
			dependencies: ["5A5B0007CCDD0007"]
			description: ["NAND Chips are integrated circuits produced from Silicon Wafers etched in acid solution. Run a Silicon Ingot through the Wiremill to produce Silicon Wafers; etch each wafer in the Chemical Bath with Sulfuric Acid to yield a NAND Chip. They are the primary logic element of Good Electronic Circuits — the MV circuit tier. Produce at least 16 before beginning circuit assembly; the batch size per circuit is non-trivial and automated Chemical Bath throughput determines your total circuit production speed."]
			id: "5A5B0008CCDD0008"
			rewards: [{
				count: 3
				id: "7A7B0008CCDD0001"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [{
				count: 8L
				id: "6A6B0008CCDD0001"
				item: { Count: 8, id: "gtceu:nand_chip" }
				type: "item"
			}]
			title: "NAND Chip"
			x: -4.0d
			y: -2.0d
		}
		{
			dependencies: ["5A5B0008CCDD0008"]
			description: ["The Good Electronic Circuit is the MV circuit tier. It combines NAND Chips, Resistors, Capacitors, and Transistors on an Integrated Logic Circuit Board — a substrate produced by chemically treating a Phenolic Circuit Board blank. The Assembler is the only practical way to produce these at volume; set up a dedicated circuit line with the Assembler before beginning MV machine construction. You will consume dozens before the end of this chapter and hundreds before MV machines are fully operational."]
			id: "5A5B0009CCDD0009"
			rewards: [
				{
					count: 4
					id: "7A7B0009CCDD0001"
					item: "kubejs:coin"
					type: "item"
