	quest_links: [ ]
	quests: [
		{
			description: ["This pack includes a wide set of utility mods that reduce friction across every play session. They do not gate content or require progression — each is available from day one. The earlier you learn them, the less time you spend on logistics. JEI answers every recipe question. JourneyMap and Waystones eliminate backtracking. Sophisticated Backpacks extend your carry capacity. Drawers and Storage absorb bulk. Pipez move items without cable routing. Paragliders and the Create Jetpack handle vertical and open-air travel. None of these require mana, soul power, or voltage — just materials and early-game time."]
			id: "QL01000000000001"
			rewards: [{
				count: 2
				id: "QL03000000000001"
				item: "mmorpg:stone/1"
				type: "item"
			}]
			shape: "diamond"
			size: 1.5d
			tasks: [{
				id: "QL02000000000001"
				title: "Read the QoL Guide"
				type: "checkmark"
			}]
			title: "Home Essentials"
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["QL01000000000001"]
			description: ["JEI (Just Enough Items) is the recipe reference for the entire pack. Press R while hovering any item to view all recipes that produce it. Press U to view all uses — every recipe that consumes it. Press F to search the item list and jump to a result. Left-click a recipe to show it in the crafting grid. Bookmark items with the Bookmark key (default: A) to build a personal watch list. JEI covers every mod in the pack — GTCEu machines, Botania, Ars Nouveau, Soul Land, Mine & Slash, and all others. Learn R and U by reflex; they replace wiki lookups entirely."]
			id: "QL01000000000002"
			rewards: [{
				count: 2
				id: "QL03000000000002"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
			tasks: [{
				id: "QL02000000000002"
				title: "Learn R and U in JEI"
				type: "checkmark"
			}]
			title: "JEI"
			x: -3.0d
			y: -2.5d
		}
		{
			dependencies: ["QL01000000000002"]
			description: ["JADE displays a tooltip on the top of the screen showing the block or entity your cursor is pointing at — its name, mod source, and configurable details like fluid level, machine progress, and energy stored. Right-click a block with an empty hand while JADE is active to pin its overlay. JADE reads GTCEu machine states, Botania mana pool fill levels, ME Network Controller status, and Mine & Slash mob stats. Press the JADE key (default: I) to toggle it. Configure the display through Options → JADE Settings to add or remove overlays you want visible during normal play."]
			id: "QL01000000000003"
			rewards: [{
				count: 2
				id: "QL03000000000003"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
			tasks: [{
				id: "QL02000000000003"
				title: "Enable JADE HUD"
				type: "checkmark"
			}]
			title: "JADE"
			x: -3.0d
			y: -4.0d
		}
		{
			dependencies: ["QL01000000000001"]
			description: ["JourneyMap runs a persistent world map in the background while you play. Press J to open the full-screen map; the minimap appears in the corner by default. Right-click the full map to place a waypoint at any location. Waypoints display as beacons visible in the world from distance — use them to mark your base, dungeon entrances, ore veins, Soul Beast spawn areas, and Mine & Slash dungeon portals. Press the waypoint manager button on the map to toggle individual beacons on and off. JourneyMap does not show underground by default; press O on the map to open Options and enable cave mapping."]
			id: "QL01000000000004"
			rewards: [{
				count: 2
				id: "QL03000000000004"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
			tasks: [{
				id: "QL02000000000004"
				title: "Place a JourneyMap Waypoint"
				type: "checkmark"
			}]
			title: "JourneyMap"
			x: 0.0d
			y: -2.5d
		}
		{
			dependencies: ["QL01000000000004"]
			description: ["Waystones are fast-travel anchor points you craft and place anywhere in the world. Right-click a Waystone to name it; named Waystones appear in a list accessible from any other Waystone. Open the Waystone GUI and click any destination name to teleport instantly — no cooldown on the first teleport, moderate cooldown on repeated jumps. Build a Waystone at your base before any long expedition, then place a second one when you find a Mine & Slash dungeon portal, Twilight Forest entry point, or Nether hub. The spawn Waystone is free and already active."]
			id: "QL01000000000005"
			rewards: [{
				count: 2
				id: "QL03000000000005"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
			tasks: [{
