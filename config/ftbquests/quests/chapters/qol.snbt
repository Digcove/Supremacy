			]
			title: "Functional Storage"
			x: 3.0d
			y: -4.0d
		}
		{
			dependencies: ["QL01000000000008"]
			description: ["Sophisticated Storage provides tiered chests with upgrade slots. Each chest tier — Wood, Iron, Gold, Diamond, Netherite — adds inventory slots, and upgrade cards further customize behavior: the Pickup Upgrade auto-collects nearby items of a filter-matching type; the Sort Upgrade keeps contents alphabetically organized; the Compacting Upgrade converts raw materials to compressed blocks automatically. Sophisticated Storage barrels function like single-item Storage Drawers but with the upgrade card system. Use Sophisticated Storage chests for miscellaneous multi-item storage where Drawers are too specific, and barrels for single-material bulk."]
			id: "QL01000000000009"
			rewards: [{
				count: 2
				id: "QL03000000000009"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
