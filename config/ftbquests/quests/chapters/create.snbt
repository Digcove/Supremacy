	quests: [
		{
			dependencies: ["409F8A64CB4B184A"]
			description: ["Create is a kinetic power mod built around Stress Units (SU). Rotational force is generated by sources like Water Wheels and Windmills, transmitted through Shafts and Cogwheels, and consumed by machines. Every machine has a stress cost — exceeding your network's capacity stalls everything connected to it. Manage your SU budget carefully as your factory grows."]
			id: "378C3A0358FD2ABD"
			tasks: [{
				id: "26533AA197A01B49"
				title: "Create"
				type: "checkmark"
			}]
			title: "Mechanisms in Motion"
			x: -1.0d
			y: 0.0d
		}
		{
			dependencies: ["378C3A0358FD2ABD"]
			description: ["Shafts transmit rotational force along a line. Cogwheels change its direction and speed — meshing a large and small cogwheel produces a 4:1 speed ratio. Greater speed increases a machine's throughput but also its stress cost. Design your drivetrain before committing resources to machines."]
			id: "369A9E51C5A05AB7"
			rewards: [{
				count: 8
