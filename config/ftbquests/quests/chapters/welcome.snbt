		}
		{
			dependencies: ["5D5D000000000001"]
			description: ["This book is the pack's documentation — every tab is a manual, not a checklist. &eMain Story&r is the spine: follow it when you do not know what to do next. &eCampaign&r is the Mine and Slash ARPG arc — acts, bosses, and the Gem Shop. &eStar Tech&r tabs are the GregTech bible, from steam to stargates, with a separate chemistry reference. &eHome Sweet Home&r covers your base: farming, storage, commerce. &eAdventure&r covers the world: dungeons, structures, dimensions, and the Armory. &eGodlike Power&r is gear optimization — armor, jewelry, ascension. Read the chapter before the grind; most of this pack's traps are documented."]
			icon: "ftbquests:book"
			id: "5D5D000000000002"
			rewards: [{
				auto: "enabled"
				command: "/mine_and_slash give xp_times_lvl @p 50"
				elevate_perms: true
				icon: "minecraft:experience_bottle"
				id: "5D5D200000000002"
				silent: true
				title: "50 Experience x Lv."
				type: "command"
			}]
			tasks: [{
				id: "5D5D100000000002"
				title: "Tour the quest book tabs"
				type: "checkmark"
			}]
			title: "How to Read This Book"
			x: -3.0d
			y: 3.0d
		}
		{
			dependencies: ["5D5D000000000001"]
			description: ["You will die in this pack, and early on you will die often — Mine and Slash mobs scale to your character level and do not respect fresh spawns. Do not panic: the &eCorpse&r mod catches everything. Death leaves a corpse at the spot holding your full inventory; walk back and click it to take it all back. Nothing despawns, nothing burns off a timer. The cost of dying is the walk. Once you can afford it, keep a recovery compass or a waystone warp on hand to make that walk short."]
			icon: "minecraft:recovery_compass"
			id: "5D5D000000000003"
			rewards: [{
				auto: "enabled"
				command: "/mine_and_slash give xp_times_lvl @p 50"
				elevate_perms: true
				icon: "minecraft:experience_bottle"
				id: "5D5D200000000003"
				silent: true
				title: "50 Experience x Lv."
				type: "command"
			}]
			tasks: [{
				id: "5D5D100000000003"
				title: "Understand death recovery"
				type: "checkmark"
