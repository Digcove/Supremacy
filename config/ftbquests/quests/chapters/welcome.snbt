				silent: true
				title: "50 Experience x Lv."
				type: "command"
			}]
			tasks: [{
				id: "5D5D100000000005"
				title: "Twilight Forest is early-game"
				type: "checkmark"
			}]
			title: "FAQ: The Twilight Opens Early"
			x: -5.0d
