		{
			dependencies: ["IV0100000000001A"]
			description: ["Naquadah is not mined so much as refined. The raw ore must be crushed, washed, and centrifuged before the EBF will accept it. Pull the first ingots from the dust before you think about stargates."]
			id: "VL01000000000001"
			rewards: [{
