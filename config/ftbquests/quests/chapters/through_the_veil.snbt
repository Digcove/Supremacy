		}
		{
			dependencies: ["VL01000000000001"]
			description: ["14 ring segments form the rotating aperture of a Classic Stargate. Each is precision-cast from naquadah alloy plate and etched with a portion of the address encoding geometry. Incomplete rings produce unstable wormholes."]
			id: "VL01000000000006"
			rewards: [{
