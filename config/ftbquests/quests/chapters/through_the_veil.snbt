			y: -2.5d
		}
		{
			dependencies: ["VL01000000000006"]
			description: ["9 chevrons lock each glyph into the gate's seven-symbol address matrix. Their geometry requires sub-millimeter manufacturing tolerance—loose chevrons let the kawoosh destabilize mid-formation."]
