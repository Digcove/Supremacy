			x: 3.0d
			y: 0.0d
		}
		{
			dependencies: ["VL01000000000002"]
			description: ["Naquadah Alloy combines enriched naquadah with Osmiridium under extreme heat. The resulting material is self-resonant—it sustains an Einstein-Rosen bridge without continuous energy input, which is the only reason stargates are practical at all."]
			id: "VL01000000000003"
			rewards: [{
