			y: 0.0d
		}
		{
			dependencies: ["VL01000000000001"]
			description: ["Enriching raw naquadah in the EBF amplifies its dimensional resonance coefficient. Every alloy in the stargate structural matrix requires this intermediate form—there is no shortcut through the smelting step."]
			id: "VL01000000000002"
			rewards: [{
