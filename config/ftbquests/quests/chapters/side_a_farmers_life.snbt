	}, {
		id: "0000000000013020"
		x: 2.0d
		y: 32.0d
		dependencies: ["0000000000013010"]
		title: "Milled Flour"
		icon: {id: "pamhc2foodcore:flouritem", Count: 1b}
		description: ["Flour is the foundation of every baked good in Pam's Harvestcraft. Use the Grinder with any grain in the crafting grid — wheat, barley, oat, rye, rice, or quinoa from your fields — to produce one flour per use. No block placement needed; the Grinder is just an ingredient in the recipe.", "Flour feeds into dough, batter, stew, and fried chicken. Build a stockpile early. Nearly every cooking chain downstream burns through it quickly, and grains are cheap to grow in bulk with Botany Pots."]
		tasks: [{
			id: "0000000000013021"
			type: "item"
			item: {id: "pamhc2foodcore:flouritem", Count: 1b}
			count: 4L
		}]
		rewards: [{
			id: "0000000000013022"
			type: "item"
			item: {id: "pamhc2crops:barleyitem", Count: 8b}
		}, {
