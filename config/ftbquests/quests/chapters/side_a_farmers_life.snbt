		}]
	}, {
		id: "0000000000013070"
		x: 12.0d
		y: 32.0d
		dependencies: ["0000000000013050"]
		title: "Sweet and Cultured"
		icon: {id: "pamhc2foodcore:caramelitem", Count: 1b}
		description: ["Yogurt is made in the Saucepan from milk alone. Caramel is milk and sugar in the same pan. Both are starting points for a wide family of flavored variants: Apple Yogurt, Caramel Ice Cream, Caramel Donuts, Caramel Cake, and more. The Saucepan reduces gently rather than boiling, producing smooth results.", "Caramel in particular threads through the entire sweet side of Pam's — keep it stocked if you plan to bake seriously. Yogurt flavors well with any fruit from your orchards and is one of the better everyday foods for its cost."]
		tasks: [{
			id: "0000000000013071"
			type: "item"
			item: {id: "pamhc2foodcore:yogurtitem", Count: 1b}
			count: 2L
		}, {
			id: "0000000000013072"
			type: "item"
			item: {id: "pamhc2foodcore:caramelitem", Count: 1b}
			count: 2L
		}]
		rewards: [{
