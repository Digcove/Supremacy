		}
		{
			dependencies: ["5E5E000000000005"]
			description: ["Supplementaries and Amendments supply the finishing details that make a town feel inhabited: sign posts pointing to the market square, notice boards for server announcements, item shelves and pedestals to showcase a flagship product, ropes, flags, and wall lanterns for the street outside. Detail is signage — it tells a passing player what a building is for before they ever click a trader. Dress the district, not just your own plot."]
			icon: "supplementaries:sign_post_oak"
