					silent: true
					title: "50 Experience x Lv."
					type: "command"
				}
				{
					count: 5
					id: "5E5E300000000005"
					item: "lightmanscurrency:coin_gold"
					type: "item"
				}
			]
			tasks: [{
				id: "5E5E100000000005"
				item: "lightmanscurrency:display_case"
				type: "item"
			}]
			title: "Your First Shop"
			x: 0.0d
			y: 2.5d
		}
		{
			dependencies: ["5E5E000000000005"]
			description: ["The Vending Machine is the Display Case grown up: many trade slots in one block, buy and sell offers side by side, and enough internal storage to run unattended for days. Configure each slot with its own price, keep the machine stocked, and it becomes passive income while you are off running maps. A wall of vending machines with clear labels is the classic server shop — one machine per product line."]
			id: "5E5E000000000006"
			rewards: [
