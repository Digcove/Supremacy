		{
			dependencies: ["5E5E000000000005"]
			description: ["Handcrafted fills the inside: counters for the till, shelves and cupboards for display stock, tables, chairs, and benches for the tavern corner. Its furniture accepts items placed on top, so real goods sit on real shelves instead of living in item frames. A counter between you and the customer, wares on the wall behind — the oldest shop layout in the world still reads instantly in Minecraft."]
			icon: "handcrafted:oak_counter"
