			}]
			title: "Goblin Bazaars"
			x: 2.5d
			y: 2.5d
		}
		{
			dependencies: ["5E5E000000000008"]
			description: ["Villagers remain the oldest trading partners in the game. Assign professions with workstations — lectern for librarians, smithing table for toolsmiths — and each villager restocks twice a day while working. A proper trading hall with a breeder, a rail of workstations, and cured discounts turns emeralds into a renewable resource. Villager goods complement the player economy rather than competing with it: enchanted books and gear from villagers, bulk materials and rare drops from players."]
			icon: "minecraft:emerald"
			id: "5E5E000000000009"
