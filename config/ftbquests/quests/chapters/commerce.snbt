		}
		{
			dependencies: ["5E5E000000000006"]
			description: ["The Trading Terminal lists every network-enabled trader on the server in one searchable interface — browse other players' shops, compare prices, and buy remotely without walking to their storefront. Flip the network setting on in your own traders and your goods appear in every terminal on the server. This is what turns scattered shop stalls into an actual economy: the moment prices are visible to everyone, competition starts."]
			id: "5E5E000000000007"
