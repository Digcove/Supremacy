		{
			dependencies: ["5E5E000000000001"]
			description: ["Goblin Traders are wandering merchants of the underground: regular goblins haunt the caves of the Overworld, and their vein cousins deal from the Nether. Their stock includes enchantments and oddities the villager economy never carries, refreshed on their own schedule. They are cowardly, easily missed, and worth stopping for every time you hear one. Strike a deal with a goblin to complete this quest."]
			icon: "goblintraders:goblin_trader_spawn_egg"
			id: "5E5E000000000008"
