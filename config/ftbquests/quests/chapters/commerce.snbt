			}]
			title: "Better Together"
			x: 5.0d
			y: 2.5d
		}
		{
			dependencies: ["5E5E00000000000A"]
			description: ["FTB Chunks protects your land. Open the map with the minimap key or the map button in your inventory, drag across the chunks you want, and they are claimed — other players cannot break, place, or open containers inside. Force-loading keeps your machines running while you are away, within a limited chunk budget. On a server, claim before you build: an unclaimed base is a suggestion, not a home. Claim your shop as well, and let the trader blocks handle the security of the goods."]
			icon: "minecraft:filled_map"
			id: "5E5E00000000000B"
