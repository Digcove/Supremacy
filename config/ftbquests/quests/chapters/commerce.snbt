		}
		{
			dependencies: ["5E5E000000000001"]
			description: ["FTB Teams binds players into a party that shares what matters: quest progress in this book is tracked per team, and land claims are held by the team rather than one player. Create or join one through the team button in your inventory screen or the /ftbteams command. On a community server a team is the difference between a base and a settlement — pool your claims, split the GT grind, and specialize. One member runs the smeltery, one runs the maps, one runs the shop."]
			icon: "minecraft:white_banner"
			id: "5E5E00000000000A"
