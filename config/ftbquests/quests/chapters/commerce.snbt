		{
			dependencies: ["5E5E000000000001"]
			description: ["The Display Case is the simplest shop in the game: place it, open it as the owner, set a trade — an item and its price — and stock it from your inventory. Any player who clicks the case sees the offer and pays coins directly into the case's storage; you collect earnings whenever you pass by. No chest-swap honor system, no sign contracts — the block enforces the deal. Sell what your base overproduces. Someone on this server needs exactly the thing you throw away."]
			id: "5E5E000000000005"
			rewards: [
				{
					auto: "enabled"
					command: "/mine_and_slash give xp_times_lvl @p 50"
					elevate_perms: true
					icon: "minecraft:experience_bottle"
