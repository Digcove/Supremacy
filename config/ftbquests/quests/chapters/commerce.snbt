	quest_links: [ ]
	quests: [
		{
			description: ["Supremacy runs on coin. Lightman's Currency provides the server's money: a chain of coins from copper and iron up through gold, emerald, diamond, and netherite, each tier worth ten of the one below it. Coins arrive as quest rewards, turn up in loot chests across the world, and — most importantly — change hands between players. Everything in this chapter builds toward one idea: the other players on this server are your market. Hold a coin and start thinking like a merchant."]
			id: "5E5E000000000001"
