			}]
			title: "Stake Your Claim"
			x: 5.0d
			y: 5.0d
		}
		{
			dependencies: ["5E5E000000000001"]
			description: ["Waystones are the server's public travel network. Craft one, place it, and name it — any player who clicks it once has it attuned and can teleport to it from any other waystone. A shop nobody can reach earns nothing: plant a waystone at your storefront and your customer base becomes the whole server instead of your neighbors. Waystones also generate naturally in villages and structures; attune every one you pass."]
			id: "5E5E00000000000C"
			rewards: [
				{
