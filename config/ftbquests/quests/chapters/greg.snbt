	quests: [
		{
			dependencies: ["7D2E4F6A8B1C3D56"]
			description: ["GregTech Community Edition is the industrial backbone of the late game. It begins simply — hand tools, iron, and fire — and escalates into vast automated factories processing every ore and alloy on the periodic table. Reaching Spirit Scholar means your cultivation has stabilized enough to direct that same discipline toward industry. The path from campfire smelting to electric machinery is long, but every step is deliberate."]
			id: "1727551BEC3E69D1"
			rewards: [{
				id: "0A1B2C3D4E5F6072"
				item: "gtceu:iron_hammer"
				type: "item"
			}]
			tasks: [{
				advancement: "soulland:cultivation/spirit_scholar"
				criterion: ""
				id: "5AABDD49B6BB5D21"
				type: "advancement"
			}]
			title: "The Way of Steel"
			x: -14.0d
			y: 0.0d
		}
		{
			dependencies: ["1727551BEC3E69D1"]
			description: ["GregTech requires specialized hand tools for nearly every crafting step. The Hammer is mandatory — it shapes ingots into plates, rods into gears, and blocks into casings. The File trims rod ends. The Wire Cutter strips cables. The Screwdriver sets circuit components. The Wrench removes machines without breaking them. Craft what you need before you need it; the recipes are cheap but the work will halt without the right tool."]
			id: "7A3F9B2E5D8C1A4F"
