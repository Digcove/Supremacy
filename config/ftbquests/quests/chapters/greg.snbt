					type: "item"
				}
			]
			title: "Glass & Vacuum Tubes"
			x: 1.0d
			y: 0.0d
		}
		{
			dependencies: ["4E2F7A9D1B5C8E6A"]
			description: ["Red Alloy is an electrical conductor made by alloying Copper and Redstone — produce it in a Create Mixer or Steam Alloy Smelter. It is used in circuit wiring and redstone-logic components. The Resin Printed Circuit Board is the first tier circuit substrate: collect Sticky Resin from a rubber tree, form it into a Resin Circuit Board, then etch it with Iron(III) Chloride or Sodium Persulfate solution in a Chemical Bath. Both are required to assemble the Basic Electronic Circuit."]
			id: "8F5D3A1E6B9C4F2B"
			rewards: [{
				count: 2
				id: "AD53FFAF2B9C6DC6"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [
