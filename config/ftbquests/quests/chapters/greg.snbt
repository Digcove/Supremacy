		{
			dependencies: ["3A9E7B2D4F8C6A1E"]
			description: ["The Basic Electronic Circuit is the first milestone of GT's electrical era. It requires Vacuum Tubes, a Resin Printed Circuit Board, Resistors, and Red Alloy wire soldered in the correct configuration. Resistors are made from Carbon Dust and Red Alloy wire — a small additional synthesis step. This circuit gates all LV electric machines. Produce several; demand is immediate and ongoing."]
			id: "6B4C8F3E1A9D5B7F"
			rewards: [{
				count: 4
				id: "14CA06B69C6D331D"
				item: "kubejs:coin"
				type: "item"
			}]
			shape: "gear"
			size: 1.5d
			tasks: [{
				id: "03B9F5A58B5C220C"
				item: "gtceu:basic_electronic_circuit"
				type: "item"
			}]
			title: "Basic Electronic Circuit"
			x: 8.5d
			y: 0.0d
		}
		{
			dependencies: ["6B4C8F3E1A9D5B7F"]
			description: ["Soul Sand, drawn from the Nether, carries latent spiritual resonance — the same force cultivators spend lifetimes purifying. Alloyed with Invar under heat, it yields the Soul Infused Ingot. Draw this into wire and it becomes a conductor that carries both electricity and soul energy simultaneously. LV Energy Converters require it specifically: without soul resonance threaded through the circuitry, the conversion between GT and standard power formats is unstable. The industrial and the spiritual are not separate systems."]
			id: "1C7D5F9A4B2E8C3A"
			rewards: [{
				count: 3
				id: "47FD39E9CF9A664A"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [
				{
					id: "25DB17C7AD7E442E"
					item: "gtceu:soul_infused_ingot"
					type: "item"
				}
				{
					count: 4L
					id: "36EC28D8BE8F553F"
					item: { Count: 4, id: "gtceu:soul_infused_single_wire" }
					type: "item"
				}
			]
			title: "Soul Infused Wire"
			x: 8.5d
			y: -2.5d
		}
		{
			dependencies: ["6B4C8F3E1A9D5B7F"]
			description: ["The LV Electric Motor converts electrical current into mechanical rotation. It is a direct prerequisite for most LV machines — the Macerator, Wiremill, Bender, Lathe, and Assembler all require one. Craft it from Iron Rod, Copper Single Wire, and a Tin Cable wound in the correct configuration using GT hand tools. The motor is cheap; building multiples now saves time when the rest of the LV machine suite comes online."]
			id: "4D1E3B7C8F6A2D9B"
			rewards: [{
				count: 2
				id: "691F5BBBF1BC886C"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [{
				id: "580E4AFAD0AB775B"
				item: "gtceu:lv_electric_motor"
				type: "item"
			}]
			title: "LV Motor"
			x: 11.0d
			y: 0.0d
		}
		{
			dependencies: [
				"4D1E3B7C8F6A2D9B"
				"1C7D5F9A4B2E8C3A"
			]
			description: ["The LV Energy Converter bridges GT's internal voltage system with the standard RF/FE power network. It requires an LV Machine Hull, a Basic Electronic Circuit, and Soul Infused Wire — the soul resonance in the wire stabilizes the conversion at low voltage. Without a Converter, no RF-producing machine can charge GT machines and vice versa. This is the gateway to powered automation: every LV machine, every cable run, every automated line begins here."]
			id: "8E5F2A9D6C4B1E7C"
