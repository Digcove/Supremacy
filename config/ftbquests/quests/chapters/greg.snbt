			]
			title: "Coke Oven"
			x: -4.0d
			y: 0.0d
		}
		{
			dependencies: ["5C1E8B4D2F7A3E9C"]
			description: ["The Low-Pressure Steam Boiler converts water and solid fuel into Steam — the power medium for GregTech's first generation of machines. Connect it to a Steam Machine Hull with Bronze fluid pipes and feed it water continuously via a GT pump or tank. Coal Coke provides the longest burn time per slot. Without steam, no early GT machine will run."]
			id: "1DB0BF33EA67FB8D"
			optional: true
			rewards: [{
				count: 2
				id: "03BF5B0C2D9E6F2C"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [{
				id: "4775F1F6A486F36E"
				item: "gtceu:lp_steam_solid_boiler"
				type: "item"
			}]
			title: "Steam Boiler"
			x: -4.0d
			y: 2.5d
		}
		{
			dependencies: ["5C1E8B4D2F7A3E9C"]
			description: ["Rubber is mandatory for GT cables — every single cable requires a rubber coating to function. Jungle Saplings tapped by a Thermal Tree Extractor produce Raw Rubber Sap; distill it into Raw Rubber, then cure it into Rubber Plates. Alternatively, the GT Latex Plantation multiblock automates the process, or a Create Mechanical Mixer with a basin and heat source can alloy it. Either path works. Stockpile rubber plates early — demand from cables, seals, and components is continuous."]
			id: "9D6A2E5F8B3C7D1E"
			rewards: [{
				count: 2
				id: "36EC8E3F5A2B9C5F"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [
				{
					id: "14CA6C1D3E0F7A3D"
					item: "minecraft:jungle_sapling"
