		}
		{
			dependencies: ["PR01000000000009"]
			description: ["The first tier of MnS Alchemy produces Health Potions and Resource Potions using Spiritual Meat, a Common Stone, and secondary food ingredients like Cooked Chicken and Apples. Health Potions restore HP over time when consumed; Resource Potions restore Mana and Energy. Both scale with the tier of Tiered Meat used — Spiritual ingredients produce Tier 0 potions; higher tiers require higher-level gathered materials. Brew in batches of 16 for dungeon runs."]
			id: "PR01000000000012"
