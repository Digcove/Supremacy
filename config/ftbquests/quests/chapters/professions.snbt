	quest_links: [ ]
	quests: [
		{
			description: ["Mine and Slash adds its own Profession system alongside the combat and gear systems. Professions are split into two categories. Gathering Professions level by doing their associated action: Mining levels by mining ores, Farming by harvesting crops, Fishing by catching fish, and Woodcutting by chopping trees. Crafting Professions level by using their station: Gear Crafting, Infusing (called Enchanting in the station UI), Cooking, and Alchemy. Salvaging is a special profession that levels by deconstructing gear in a Salvaging Station. Note that no Profession can exceed your Mine and Slash character level."]
			id: "PR01000000000001"
			rewards: [{
				count: 10
				id: "PR03000000000001"
				item: "mmorpg:stone/1"
				type: "item"
			}]
			tasks: [{
				id: "PR02000000000001"
				title: "Read the Professions Overview"
				type: "checkmark"
			}]
			title: "Professions Overview"
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["PR01000000000001"]
			description: ["Mining any ore grants Mining experience, but you only receive the full amount from ores within your current Mining level range. Tier 0 (level 1-20): Coal, Iron, Copper. Tier 1 (21-40): Redstone, Lapis, Gold, Quartz, Emerald. Tier 2 (41-60): Diamond, Undergarden ores. Tier 3 (61-80): Twilight Forest rares. Tier 4 (81-100): Upper-dimension ores. Tier 5 (100): Godly tier. While mining in-range ores, Tiered Ore drops by chance — Spiritual, Celestial, Empyrean, Angelic, Divine, and Godly — used in Gear Crafting and Infusing recipes."]
			id: "PR01000000000002"
			rewards: [{
				count: 10
				id: "PR03000000000002"
				item: "mmorpg:material/mining/0"
				type: "item"
			}]
