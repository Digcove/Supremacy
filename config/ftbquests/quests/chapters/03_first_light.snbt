		}]
	}, {
		id: "000000000000B00A"
		x: 6.0d
		y: 0.0d
		dependencies: ["000000000000B007"]
		title: "The Scribes Table"
		icon: {id: "ars_nouveau:scribes_table", Count: 1b}
		description: ["Spells are assembled at the Scribes Table — glyphs are physical items you craft and drag into slots. Form comes first. Then Effect. Augments modify both.", "Projectile + Ignite is your first viable spell. It fires forward and sets things on fire. Simple, effective, a starting point."]
		tasks: [{
			id: "000000000000B00B"
			type: "item"
			item: {id: "ars_nouveau:scribes_table", Count: 1b}
		}]
