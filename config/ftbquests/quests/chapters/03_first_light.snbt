		}]
	}, {
		id: "000000000000B007"
		x: 4.0d
		y: 0.0d
		dependencies: ["000000000000B004"]
		title: "The Source Well"
		icon: {id: "ars_nouveau:source_jar", Count: 1b}
		description: ["Source Jars fill passively near Source Berry Bushes, Archwood trees, or other Ars structures. Place one near your Archwood grove and watch the bar climb.", "Source is what everything in this mod costs — spells, glyph crafting, automation. Plant Source Berry Bushes around your base now and keep planting them. They are the cheapest Source there is."]
		tasks: [{
			id: "000000000000B008"
			type: "item"
