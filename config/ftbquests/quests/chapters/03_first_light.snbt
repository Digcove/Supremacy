		x: 2.0d
		y: 0.0d
		dependencies: ["000000000000B001"]
		title: "The Arcane Compendium"
		icon: {id: "ars_nouveau:arcane_compendium", Count: 1b}
		description: ["Hold a Book and Quill near a bookshelf that has Source nearby and right-click. The Arcane Compendium assembles itself — it is the complete field guide to Ars Nouveau.", "Read the Glyphs section. The grammar here is Form → Effect → Augment. Everything you cast is built from that."]
		tasks: [{
			id: "000000000000B005"
