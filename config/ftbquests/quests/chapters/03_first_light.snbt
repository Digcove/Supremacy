		}]
	}, {
		id: "000000000000B00E"
		x: 8.0d
		y: 0.0d
		dependencies: ["000000000000B00A"]
		title: "First Fire"
		icon: {id: "ars_nouveau:novice_spellbook", Count: 1b}
		description: ["Slot Projectile then Ignite into the Scribes Table. Drag it into your Novice Spellbook. Press R. That is a spell. It costs Source, it works, and it's yours.", "The Novice book holds a few spells. Build a rotation now — at least one damage spell, one utility."]
		tasks: [{
