		{
			dependencies: ["5497889D31975BB4"]
			icon: "botania:apothecary_default"
			description: ["The Petal Apothecary converts flower petals into Botania's functional flowers. Fill it with water, then throw in the crafting ingredients listed in the Lexica Botania. Endoflames — which burn fuel to generate mana — are your first priority. Craft four and point a Mana Spreader at a Mana Pool to establish your first mana supply."]
			id: "75C157B691AC5AFE"
