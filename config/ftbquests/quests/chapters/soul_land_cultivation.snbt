			y: -2.0d
		}
		{
			dependencies: [
				"5B7F342A6DC75143"
				"6CD3FDD027906C44"
			]
			description: ["The Open Crate drops items directly below it when a Redstone signal is applied. Place one above your Endoflames with a pressure plate trigger to automate fuel delivery. This eliminates the single largest maintenance burden in early Botania and frees you to focus on building the rest of your mana infrastructure."]
			id: "73045CEAB13DB4AD"
