			title: "First Mana Pool"
			x: 5.5d
			y: -2.0d
		}
		{
			dependencies: ["75C157B691AC5AFE"]
			description: ["The Endoflame is Botania's entry-level generating flower. It burns solid fuels — coal, charcoal, and coal blocks — to produce mana. Coal blocks are the most efficient fuel per slot. A bank of four Endoflames feeding a single Spreader provides a reliable baseline mana supply while you build toward more efficient flowers."]
			id: "5B7F342A6DC75143"
			tasks: [{
				count: 4L
				id: "39E51FDE01B10F0A"
