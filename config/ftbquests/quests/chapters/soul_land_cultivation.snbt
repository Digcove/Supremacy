	quests: [
		{
			dependencies: ["33EAD812978BAB9C"]
			description: ["Your martial soul has awakened. The Soul Land mod tracks your cultivation rank from 1 to 120 across 14 stages — from Spirit Scholar to God. Your Talent score, assigned at birth, determines your starting pace but not your ceiling. Meditate regularly at your Cultivation Altar, use herbs wisely, and always complete your breakthrough cycles."]
			id: "330FEE9467B9D8A6"
			rewards: [{
				id: "5C6DA795C4125F36"
