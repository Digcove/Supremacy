			}]
			title: "The First Awakening"
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["330FEE9467B9D8A6"]
			description: ["A Soul Ring is absorbed from a defeated spirit beast. The White Ring comes from a 10-year beast — found in the Star Dou Forest Edge. Each ring permanently enhances one of your martial soul's skills; rings cannot be removed once absorbed. The age and species of the beast determines the ring's power. Choose carefully — you only get nine rings across your entire lifetime."]
			id: "5FC6C2D842B38AD2"
			rewards: [{
				count: 2
				id: "6A1B1D2DEBDF475A"
