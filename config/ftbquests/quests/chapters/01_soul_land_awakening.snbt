	, {
		id: "0000000000003020"
		x: 10.0d
		y: 0.0d
		dependencies: ["0000000000003014"]
		title: "The Melter"
		icon: {id: "tconstruct:melter", Count: 1b}
		description: ["The Melter is your first Tinkers' casting station — a single block that liquefies metals when placed above a heat source. It is smaller than the Smeltery and faster to set up.", "To build one you need Seared Bricks, which come from Grout. Grout is crafted in equal parts sand, gravel, and clay — any ratio works as long as the proportions match. Smelt the Grout in a furnace to get Seared Bricks. Stack enough bricks to build the Melter block itself.", "Place the Melter one block above a flame or Seared Heater. Set a Casting Table directly beneath the drain on its side. Pour molten metal from the Melter into a Cast on the table to produce tool parts. This is the full casting workflow — learn it here before building the Smeltery."]
		tasks: [{
			id: "0000000000003021"
			type: "item"
			item: {id: "tconstruct:melter", Count: 1b}
		}]
		rewards: [{
			id: "0000000000003022"
			type: "item"
			item: {id: "tconstruct:grout", Count: 16b}
		}, {
			id: "0000000000003023"
			type: "item"
			item: {id: "tconstruct:casting_table", Count: 1b}
		}]
	}]
	, {
		id: "0000000000003024"
		x: 12.0d
		y: 0.0d
		dependencies: ["0000000000003020"]
		title: "The Smeltery"
		icon: {id: "tconstruct:smeltery_controller", Count: 1b}
		description: ["The Smeltery is the Melter's bigger sibling — a hollow multiblock that holds multiple metals at once, alloys them together, and processes ore at double output. Where the Melter handles one metal at a time, the Smeltery handles everything simultaneously.", "Build it as a hollow box of Seared Bricks: at minimum a 3×2×3 interior with the Smeltery Controller on one wall, a Seared Tank for fuel on another, and a Seared Drain to pour from. The structure must be fully enclosed — no gaps. Right-click the Controller when built and it will confirm formation.", "The ore doubling is the reason to build this. Raw ore into the Smeltery produces two ingots per ore. Run everything through it. The Casting Basin below the drain lets you pour large quantities at once into ingot molds or full block casts."]
		tasks: [{
			id: "0000000000003025"
			type: "item"
			item: {id: "tconstruct:smeltery_controller", Count: 1b}
		}]
		rewards: [{
			id: "0000000000003026"
			type: "item"
			item: {id: "tconstruct:seared_brick", Count: 32b}
