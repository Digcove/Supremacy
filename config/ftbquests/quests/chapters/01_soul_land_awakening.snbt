		can_repeat: true
		title: "A Soul Awakens"
		icon: {id: "minecraft:dirt", Count: 1b}
		description: ["You have arrived. The continent of Douluo spreads before you — strange, dangerous, and alive with a power you don't yet understand.", "This questbook is your guide through Soul Land. It will walk you through cultivation, spirit rings, martial souls, the Tinkers' workshop, and the Mine & Slash combat system that ties everything together. Read each description before completing the task. The answers to most early questions are written here.", "Pick up a handful of dirt. Then begin."]
		tasks: [{
			id: "0000000000003002"
			type: "item"
			item: {id: "minecraft:dirt", Count: 1b}
			consume: true
		}]
		rewards: [{
			id: "0000000000003003"
			type: "item"
			item: {id: "mmorpg:master_bag", Count: 1b}
		}]
	}, {
		id: "0000000000003004"
		x: 2.0d
		y: 0.0d
		dependencies: ["0000000000003001"]
		title: "Into the Wood"
		icon: {id: "minecraft:oak_log", Count: 1b}
		description: ["Wood comes before tools. Sixteen logs gets you a crafting table, the planks for a shelter, and enough material to start the Tinkers' early recipes. Any tree works — oak, birch, spruce, whatever's nearest.", "The Tinkers' Construct system replaces standard tools in this pack. A wooden axe will never be more than a stepping stone. Get the logs and move on."]
		tasks: [{
			id: "0000000000003005"
			type: "item"
			item: {
				Count: 1
				id: "itemfilters:tag"
				tag: {
					value: "minecraft:logs"
				}
			}
			count: 16L
		}]
		rewards: [{
			id: "0000000000003006"
			type: "item"
			item: {id: "tconstruct:blank_pattern", Count: 4b}
		}]
	}, {
		id: "0000000000003007"
		x: 4.0d
		y: 0.0d
		dependencies: ["0000000000003004"]
		title: "The Tinker's Workshop"
		icon: {id: "tconstruct:tool_station", Count: 1b}
		description: ["Tinkers' Construct builds tools in parts rather than patterns. The Tool Station assembles parts into finished tools. The Part Builder carves raw materials into parts. The Stencil Table stamps blank patterns into shapes. The Pattern Chest stores them all.", "Build all four and place them together — you'll use them as a set. This cluster is the workshop that replaces the vanilla crafting table for anything tool-related from here forward.", "The reward parts have different properties. Copper is easy to work and easy to repair. Cactus carries the Jagged trait — damage scales with your missing health. Paper has more modifier slots than any other material but low durability. Pick what fits your first tool design."]
		tasks: [{
			id: "0000000000003008"
			type: "item"
			item: {id: "tconstruct:tool_station", Count: 1b}
		}, {
			id: "0000000000003009"
			type: "item"
			item: {id: "tconstruct:part_builder", Count: 1b}
		}, {
			id: "000000000000300A"
