			item: {id: "tconstruct:binding", Count: 1b, tag: {"tconstruct:materials": ["tconstruct:paper"]}}
		}]
	}, {
		id: "000000000000300F"
		x: 6.0d
		y: 0.0d
		dependencies: ["0000000000003007"]
		title: "First Cast"
		icon: {id: "tconstruct:pickaxe", Count: 1b}
		description: ["Take a pickaxe head, a tool rod, and a binding to the Tool Station. Slot them in the correct positions and pull out the result. That is a Tinkers' pickaxe.", "It won't outperform iron immediately. It will within a few upgrades. Tinkers' tools gain experience from use, accumulate modifier slots, and can be repaired with the same material they were built from. The ceiling is far above anything vanilla offers.", "The reward parts are components for your next build. Obsidian tool rods carry Reinforced — reduced durability loss per swing. Cactus bindings add Jagged. The copper shovel head is the start of a complete digging set."]
		tasks: [{
			id: "0000000000003010"
			type: "item"
			item: {id: "tconstruct:pickaxe", Count: 1b}
		}]
		rewards: [{
			id: "0000000000003011"
			type: "item"
			item: {id: "tconstruct:tool_rod", Count: 1b, tag: {"tconstruct:materials": ["tconstruct:obsidian"]}}
