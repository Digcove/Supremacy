			type: "item"
			item: {id: "tconstruct:axe_head", Count: 1b, tag: {"tconstruct:materials": ["tconstruct:copper"]}}
		}, {
			id: "000000000000300D"
			type: "item"
			item: {id: "tconstruct:tool_rod", Count: 1b, tag: {"tconstruct:materials": ["tconstruct:cactus"]}}
