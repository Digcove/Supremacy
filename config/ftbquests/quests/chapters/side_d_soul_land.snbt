	}, {
		id: "000000000000EF1E"
		x: 8.0d
		y: -6.0d
		dependencies: ["000000000000EF12"]
		title: "The Tang Sect Arsenal"
		icon: {id: "soulland:forging_table", Count: 1b}
		description: ["The Forging Table has 16 hidden weapon recipes: Sleeve Darts and Throwing Needles at the low end, scaling through Flash Bombs, Bone Claws, and Shock Crossbows up to the Godly Zhuge Crossbow (48 arrows per volley) and Peacock Plume (365 needles in a spread fan).", "Two one-use legendary items exist: Yama\'s Invitation and Bodhi Blood. Both are endgame consumables reserved for fights where a guaranteed kill matters more than a reusable tool. Build the Crossbow first."]
		tasks: [{
			id: "000000000000EF1F"
			type: "checkmark"
			title: "Craft any Tang Sect hidden weapon at the Forging Table"
		}]
		rewards: [{
			id: "000000000000EF20"
