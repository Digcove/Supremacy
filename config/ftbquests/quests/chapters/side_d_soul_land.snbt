		y: 2.0d
		dependencies: ["000000000000A040"]
		title: "Foundation Pill"
		icon: {id: "soulland:foundation_pill", Count: 1b}
		description: ["The Foundation Pill increases Soul Power gain rate for a period after consuming it. Take one before any extended meditation session — it's the difference between ranking up overnight and ranking up in a week.", "Crafted from basic Spirit Herbs at the Forging Table. Keep a stack. Every cultivation push benefits from one."]
