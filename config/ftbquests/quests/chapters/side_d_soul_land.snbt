	}, {
		id: "000000000024A001"
		x: 0.0d
		y: 4.0d
		dependencies: ["000000000000A02C"]
		title: "The Gear Crafting Station"
		icon: {id: "mmorpg:stat_soul/family/weapon/uncommon", Count: 1b}
		description: ["The Gear Crafting Station is the Mine & Slash block that bridges Soul Land gear with the stat soul crafting system. It accepts Soul Land weapons and armor as crafting bases — Spirit Iron for Uncommon souls, Spirit Steel for Rare, Soul Forged for Epic and beyond. Place it near your Forging Table.", "Open JEI and look under the Gear Crafting Station tab to see all 60 stat soul recipes. Start with a weapon soul. Every soul you apply to a piece of gear stacks — there is no cap. This is the primary character power lever in the pack."]
		tasks: [{
			id: "000000000024A002"
			type: "checkmark"
			title: "Build the Gear Crafting Station (Mine and Slash block)"
		}]
		rewards: [{
			id: "000000000024A003"
			type: "item"
			item: {id: "mmorpg:stone/1", Count: 2b}
		}]
	}, {
		id: "000000000024A004"
		x: 2.0d
		y: 4.0d
		dependencies: ["000000000024A001"]
		title: "First Stat Soul"
		icon: {id: "mmorpg:stat_soul/family/weapon/uncommon", Count: 1b}
		description: ["Uncommon Stat Souls are the entry point. Use a Spirit Iron Sword as the crafting base at the Gear Crafting Station, combined with a Common Stone (stone/1). The resulting soul grants 2-4 stat points.", "Right-click the soul on any equipped gear piece to apply it. The stats absorb permanently. Stack as many as you have materials for — 8 to 12 on a single weapon is achievable early on and represents a significant combat spike over bare gear."]
		tasks: [{
			id: "000000000024A005"
			type: "checkmark"
			title: "Craft an Uncommon Stat Soul at the Gear Crafting Station"
		}]
