		}]
	}, {
		id: "000000000000EF15"
		x: 2.0d
		y: -6.0d
		dependencies: ["000000000000EF12"]
		title: "Purple Demon Eyes"
		icon: {id: "soulland:cultivation_manual", Count: 1b}
		description: ["Press [P] to activate Purple Demon Eyes — a four-tier mental technique that starts as night vision and escalates through ranged mental damage beams to a full AoE stun domain at Tier 4.", "The technique trains through use: keep using it in combat. Tier 1 is available immediately. Tier 4 is a battlefield-control tool that stops entire groups of enemies in place."]
		tasks: [{
			id: "000000000000EF16"
			type: "checkmark"
			title: "Activate Purple Demon Eyes [P] and use it in combat"
		}]
		rewards: [{
