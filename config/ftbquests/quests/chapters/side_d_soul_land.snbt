		}]


	}, {
		id: "000000000000EF12"
		x: 0.0d
		y: -6.0d
		dependencies: ["000000000000BD01"]
		title: "The Hidden Arts"
		icon: {id: "soulland:forging_table", Count: 1b}
		description: ["The Tang Sect is the pack\'s hidden weapon and technique tradition. Three signature techniques are activated by hotkeys, trained through use, and progress through tiers that unlock new mechanics at each stage.", "Hidden Weapons are crafted at the Forging Table — 16 weapons from basic Sleeve Darts to the Godly Zhuge Crossbow (48 arrows per volley) and the Peacock Plume (365 needles in a fan pattern). Tier by tier, the Tang Sect arsenal expands into the endgame."]
		tasks: [{
			id: "000000000000EF13"
			type: "checkmark"
			title: "Read this introduction to the Tang Sect and its three techniques"
		}]
		rewards: [{
