			item: {id: "mmorpg:stone/2", Count: 2b}
		}]
	}, {
		id: "000000000000A018"
		x: 14.0d
		y: 0.0d
		dependencies: ["000000000000A014"]
		title: "Dragon Realm"
		icon: {id: "soulland:dragon_roost_stone", Count: 1b}
		description: ["A hole was torn in reality. The Dragon Dimension generates its own biomes — Dragon Roost forests, Silver Pine groves, Celestial Dragon Stone formations. Bring it all back. The blocks feed into the Soul Land Forging Table for the highest-tier crafting.", "Beyond the dimension entrance, three divine paths diverge. Sea God, Seraph, or Asura. Each defines the endgame shape of your Soul Land build. Choose after you've explored enough to know what you want."]
		tasks: [{
			id: "000000000000A019"
			type: "item"
			item: {id: "soulland:dragon_roost_stone", Count: 1b}
