		}]
	}, {
		id: "000000000000EF37"
		x: 12.0d
		y: 2.0d
		dependencies: ["000000000000EF34"]
		title: "Alchemy: The Full Art"
		icon: {id: "soulland:foundation_pill", Count: 1b}
		description: ["Alchemy runs on a 10-tier progression from Novice to Legendary Alchemist. You begin with only 3 starter recipes. Every additional formula must be discovered — through dungeon chests, NPC rewards, beast drops, and boss kills.", "Base success rate is 25% (higher than it sounds once skill improves). Herb XP is capped: diminishing returns after 3 uses of the same herb, and meditation speed is 43% slower without alchemy supplementing your cultivation. Alchemy is not optional for fast progression — it\'s the engine."]
		tasks: [{
			id: "000000000000EF38"
			type: "checkmark"
			title: "Discover a new alchemy recipe (dungeon, NPC trade, or boss drop)"
		}]
