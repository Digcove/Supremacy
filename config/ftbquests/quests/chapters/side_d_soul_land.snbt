	}, {
		id: "000000000000A01D"
		x: 16.0d
		y: -1.0d
		dependencies: ["000000000000A018"]
		title: "Sea God's Grace"
		icon: {id: "soulland:sea_god_chestplate", Count: 1b}
		description: ["Tang San's path. The Sea God set is the endurance-and-ocean divine line — best suited for builds that want to outlast everything in a fight. Pairs naturally with high Defense and Resistance stacking from M&S stat souls.", "The Sea God Trident is available on this path as well. Bring it to a fight. The sea doesn't run out of patience."]
		tasks: [{
			id: "000000000000A01E"
			type: "item"
			item: {id: "soulland:sea_god_chestplate", Count: 1b}
