			item: {id: "soulland:spirit_iron_ingot", Count: 4b}
		}]
	}, {
		id: "000000000000A02F"
		x: 6.0d
		y: -2.0d
		dependencies: ["000000000000A02C"]
		title: "Spirit Iron Arms"
		icon: {id: "soulland:spirit_iron_sword", Count: 1b}
		description: ["Spirit Iron weapons deal bonus damage against spirit beasts specifically — which is most of what you'll be fighting in this chapter. They're stronger than iron but not quite soul forged.", "Craft the sword for hunting and the pickaxe for mining. The sword is what gets you the next ring tier."]
		tasks: [{
