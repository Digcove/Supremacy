{
	id: "0000000000002011"
	group: "0000000000001002"
	order_index: 19
	filename: "side_d_soul_land"
	title: "Soul Land"
	icon: {id: "soulland:cultivation_altar", Count: 1b}
	default_quest_shape: ""
	default_hide_dependency_lines: false
	groups: []
	quests: [{
		id: "000000000000A050"
		x: -2.0d
		y: 0.0d
		dependencies: ["000000000000BD01"]
		title: "The Cultivation Manual"
		icon: {id: "soulland:cultivation_manual", Count: 1b}
		description: ["The Cultivation Manual is Soul Land's reference guide — it covers the cultivation rank system, Soul Ring absorption, Martial Soul forms, Spirit Beast hunting, and the Forging Table recipes.", "Craft it at the Forging Table. Read it before your first meditation session. The rank progression (Spirit Scholar → Spirit Master → Soul Master → ...) and the ring color hierarchy (White → Yellow → Purple → Black → Red → Gold) are both explained inside."]
		tasks: [{
			id: "000000000000A051"
			type: "checkmark"
			title: "Craft and read the Cultivation Manual"
		}]
		rewards: [{
			id: "000000000000A052"
			type: "item"
			item: {id: "soulland:spirit_condensing_pill", Count: 1b}
		}]
	}, {
		id: "000000000000A001"
		x: 0.0d
		y: 0.0d
		dependencies: ["000000000000BD01"]
		title: "Cultivation Altar"
		icon: {id: "soulland:cultivation_altar", Count: 1b}
		description: ["Soul Land adds a second progression axis that runs under everything else in this pack. Cultivation ranks, Soul Rings, Martial Souls, spirit beast hunting — it feeds directly into combat power and sits comfortably alongside Mine & Slash stat building.", "Build the Cultivation Altar. This is where soul power accumulates during meditation. Plant it somewhere permanent — you'll be coming back to it every time you need to rank up.", "Soul Land cultivation runs parallel to M&S stat building. Soul Rings grant active combat skills through absorption. Stat Souls grant passive stat points through application. Both systems feed the same endgame.", "The Gear Crafting Station (M&S block) now accepts Soul Land armor and weapon pieces as crafting bases for stat souls. Spirit Cloth → early souls. Soul Forged → mid souls. Sea God armor → endgame souls. You no longer need vanilla iron gear as the base — Soul Land replaces it tier for tier."]
		tasks: [{
			id: "000000000000A002"
			type: "item"
			item: {id: "soulland:cultivation_altar", Count: 1b}
		}]
		rewards: [{
			id: "000000000000A003"
			type: "item"
			item: {id: "mmorpg:stone/0", Count: 2b}
		}]
	}, {
		id: "000000000000A004"
		x: 2.0d
		y: 0.0d
		dependencies: ["000000000000A001"]
		title: "A Soul Is Born"
		icon: {id: "soulland:cultivation_manual", Count: 1b}
		description: ["Stand at your Cultivation Altar and press [M] to meditate. The Soul Land HUD will appear: your rank, soul power, ring slots, active skills.", "Your innate talent was assigned the moment you spawned — check it. A 20 is a god that hasn't happened yet. A 1 still gets nine rings eventually and still wins. Talent is a head start, not a ceiling."]
		tasks: [{
			id: "000000000000A005"
			type: "checkmark"
			title: "Meditate for the first time [M] and check your Innate Talent in the HUD"
		}]
		rewards: [{
			id: "000000000000A006"
			type: "item"
			item: {id: "minecraft:golden_apple", Count: 1b}
		}]
	}, {
		id: "000000000000A007"
		x: 4.0d
		y: 0.0d
		dependencies: ["000000000000A004"]
		title: "First Hunt"
		icon: {id: "soulland:white_soul_ring", Count: 1b}
		description: ["Spirit Beasts drop their Soul Ring as a physical item when killed. Pick up the White Soul Ring and right-click to absorb it — it merges into your soul permanently and grants your first active skill.", "Your Spirit Detector (craft one from the Forging Table — see the bottom track) pulses when Spirit Beasts are nearby and shows approximate age. A White ring comes from a ten-year beast. They're everywhere. Go get one."]
		tasks: [{
			id: "000000000000A008"
			type: "item"
			item: {id: "soulland:white_soul_ring", Count: 1b}
		}]
		rewards: [{
			id: "000000000000A009"
			type: "item"
			item: {id: "minecraft:cooked_beef", Count: 4b}
		}]
	}, {
		id: "000000000000A00A"
		x: 6.0d
		y: 0.0d
		dependencies: ["000000000000A007"]
		title: "The Scholar Earns His Title"
		icon: {id: "soulland:spirit_condensing_pill", Count: 1b}
		description: ["Ten points of Soul Power and you graduate from nothing to Spirit Scholar. The first rank. The weakest. The one every legend has to start from.", "There are 14 ranks total. Soul power runs from 1 to 120. Keep meditating at the Cultivation Altar. The Foundation Pill (see the top track) accelerates this. Patience is a build."]
		tasks: [{
			id: "000000000000A00B"
			type: "checkmark"
			title: "Reach Rank 1: Spirit Scholar (Soul Power 10)"
		}]
		rewards: [{
			id: "000000000000A00C"
			type: "item"
			item: {id: "mmorpg:stat_soul/family/weapon/uncommon", Count: 1b}
		}]
	}, {
		id: "000000000000A00D"
		x: 8.0d
		y: 0.0d
		dependencies: ["000000000000A00A"]
		title: "A Hundred Years in Your Veins"
		icon: {id: "soulland:yellow_soul_ring", Count: 1b}
		description: ["White rings are the training wheels. A Yellow Soul Ring comes from a Spirit Beast that lived a full century — its compressed soul power is not trivial.", "A hundred-year beast hits harder than anything White dropped. Bring a Spirit Iron weapon (bottom track) or whatever hits hardest right now. The skill it grants changes how your combat rotation works."]
		tasks: [{
			id: "000000000000A00E"
			type: "item"
			item: {id: "soulland:yellow_soul_ring", Count: 1b}
		}]
		rewards: [{
			id: "000000000000A00F"
			type: "item"
			item: {id: "mmorpg:stone/1", Count: 3b}
		}]
	}, {
		id: "000000000000A010"
		x: 10.0d
		y: 0.0d
		dependencies: ["000000000000A00D"]
		title: "True Form"
		icon: {id: "soulland:blue_silver_emperor_essence", Count: 1b}
		description: ["By Soul Power 70 you are deep into T2 transformation territory. Press [V] to see your current form — at this rank the chest and head features are fully manifested. T3 and the full Spirit Avatar require Soul Power 90.", "The Transformation and Evolution systems are separate. The Martial Soul Evolution Track (lower section of this chapter) covers the four evolution stages — Awakened, Evolved, True, Divine — each multiplying base stats up to 4× at Divine. The relics to begin evolution (Blue Silver Emperor Essence) are craftable at this rank."]
		tasks: [{
			id: "000000000000A011"
			type: "checkmark"
			title: "Activate True Martial Soul Transformation at Soul Power 70+ [V]"
		}]
		rewards: [{
			id: "000000000000A012"
			type: "item"
			item: {id: "mmorpg:stat_soul/family/armor/uncommon", Count: 2b}
		}, {
			id: "000000000000A013"
			type: "item"
			item: {id: "mmorpg:stat_soul/family/weapon/uncommon", Count: 2b}
		}]
	}, {
		id: "000000000000A014"
		x: 12.0d
		y: 0.0d
		dependencies: ["000000000000A010"]
		title: "The Purple Ring"
		icon: {id: "soulland:purple_soul_ring", Count: 1b}
		description: ["A thousand years of life compressed into a ring. Purple Soul Rings unlock skills that change how you fight — not just bigger numbers, but new mechanics, new effects, new angles of attack.", "A thousand-year beast is a dungeon boss that spawns in the open world. Bring your best M&S affixes, a socketed weapon, and at least one spell scroll from Iron's Spellbooks. It has had time to get very good at this."]
		tasks: [{
			id: "000000000000A015"
			type: "item"
			item: {id: "soulland:purple_soul_ring", Count: 1b}
		}]
		rewards: [{
