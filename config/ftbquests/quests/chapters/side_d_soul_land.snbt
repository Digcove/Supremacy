	}, {
		id: "000000000000A025"
		x: 16.0d
		y: 1.0d
		dependencies: ["000000000000A018"]
		title: "The Asura Way"
		icon: {id: "soulland:asura_chestplate", Count: 1b}
		description: ["The Asura set leans hard into raw offensive output. Each piece amplifies soul skill damage at the cost of survivability. It expects you to kill fast enough that defense is irrelevant.", "Pairs best with the Plate Path from Chapter 1 and high Strength and Attack Speed from M&S. Bring the Asura God Saber. This build does not negotiate."]
		tasks: [{
