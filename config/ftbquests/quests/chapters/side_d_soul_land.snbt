			item: {id: "minecraft:bread", Count: 4b}
		}]
	}, {
		id: "000000000000A043"
		x: 6.0d
		y: 2.0d
		dependencies: ["000000000000A040"]
		title: "Foundation Pill"
		icon: {id: "soulland:foundation_pill", Count: 1b}
		description: ["The Foundation Pill increases Soul Power gain rate for a period after consuming it. Take one before any meditation session — it compounds with the reduced baseline speed after the economy rebalance.", "Alchemy is the engine behind efficient cultivation: 10 tiers from Novice to Legendary Alchemist, starting with 3 recipes you know and expanding through dungeon finds, NPC trades, and boss drops. Base success rate is 25%. Without alchemy supplementing meditation, progression is 43% slower than it used to be. The Herb Refinement Ritual (hold-to-channel on any herb) extracts more Qi per use and reduces foundation instability. See the Alchemy track further along this chapter."]
		tasks: [{
			id: "000000000000A044"
			type: "item"
			item: {id: "soulland:foundation_pill", Count: 1b}
		}]
		rewards: [{
