	}, {
		id: "000000000000A029"
		x: 2.0d
		y: -2.0d
		dependencies: ["000000000000BD01"]
		title: "The Spirit Vein"
		icon: {id: "soulland:spirit_iron_raw", Count: 1b}
		description: ["Spirit Iron Ore spawns in the same depth bands as regular iron but glows faintly blue-grey. Mine it and it drops Raw Spirit Iron - smelt that into ingots. The Create Millstone will process the ore for doubled output just like vanilla ore.", "Spirit Iron Ingots are the base material for everything in the Soul Land crafting line - tools, weapons, armor, and the Forging Table itself. Mine it early and often."]
		tasks: [{
			id: "000000000000A02A"
			type: "item"
			item: {id: "soulland:spirit_iron_raw", Count: 1b}
			count: 4L
