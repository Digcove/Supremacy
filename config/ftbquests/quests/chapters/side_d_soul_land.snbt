		}]
	}, {
		id: "000000000000EF0B"
		x: 6.0d
		y: -4.0d
		dependencies: ["000000000000EF04"]
		title: "Relic: Blue Silver Emperor Essence"
		icon: {id: "soulland:blue_silver_emperor_essence", Count: 1b}
		description: ["Martial Soul Evolution goes beyond transformation tiers. Four stages exist: Awakened, Evolved, True, and Divine — each multiplying your base stats up to 4× at the Divine stage.", "The Blue Silver Emperor Essence is the first evolution relic. Craft it at the Forging Table at Soul Power 70+. It enables the Evolved stage — the first step past your martial soul\'s base form and into something that rewrites your stat ceiling."]
		tasks: [{
			id: "000000000000EF0C"
			type: "item"
			item: {id: "soulland:blue_silver_emperor_essence", Count: 1b}
		}]
