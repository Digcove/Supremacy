			item: {id: "mmorpg:currency/orb_of_quality", Count: 2b}
		}]
	}, {
		id: "000000000000EF18"
		x: 4.0d
		y: -6.0d
		dependencies: ["000000000000EF15"]
		title: "Ghost Shadow Track"
		icon: {id: "soulland:cultivation_manual", Count: 1b}
		description: ["Press [N] for Ghost Shadow Track — a three-tier movement technique. Tier 1 is an enhanced dash. Tier 2 becomes a 20-block teleport. Tier 3 adds invisibility on use, grants 35% passive dodge, and makes positioning in any fight trivial.", "Max tier Ghost Shadow Track is a stealth, gap-close, and dodge tool combined into one hotkey. Train it continuously."]
		tasks: [{
			id: "000000000000EF19"
			type: "checkmark"
			title: "Activate Ghost Shadow Track [N] and dash in combat"
		}]
		rewards: [{
			id: "000000000000EF1A"
			type: "item"
			item: {id: "mmorpg:currency/socket_adder", Count: 1b}
		}]
	}, {
		id: "000000000000EF1B"
		x: 6.0d
		y: -6.0d
		dependencies: ["000000000000EF15"]
		title: "Controlling Crane, Capturing Dragon"
		icon: {id: "soulland:cultivation_manual", Count: 1b}
		description: ["Press [H] for Controlling Crane Capturing Dragon — a telekinesis technique with three tiers. Tier 1 pushes or pulls single targets. Tier 2 chains multiple targets and deflects arrows. Tier 3 controls 8 targets simultaneously and works on boss-tier enemies.", "At max tier this is a crowd control tool with no parallel elsewhere in the pack. It stacks with Purple Demon Eyes AoE stun for complete battlefield lockdown."]
		tasks: [{
			id: "000000000000EF1C"
			type: "checkmark"
			title: "Activate Controlling Crane Capturing Dragon [H] and use it on an enemy"
		}]
		rewards: [{
