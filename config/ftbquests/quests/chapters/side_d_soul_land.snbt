			item: {id: "mmorpg:stone/2", Count: 2b}
		}]
	}, {
		id: "000000000000EF0E"
		x: 8.0d
		y: -4.0d
		dependencies: ["000000000000EF0B"]
		title: "True and Divine"
		icon: {id: "soulland:soul_crystal", Count: 1b}
		description: ["The True and Divine evolution stages require two more relics: the Phoenix Feather Crown at Soul Power 80+, and Heaven Dream Silk at 85+. Both are crafted at the Forging Table.", "True stage: 3× stat multiplier. Divine stage: 4×. The multiplier compounds on top of every stat soul, every gem, every M&S affix you\'ve stacked. At Divine, a fully built character in this pack stops being challenged by anything below the hardest Atlas endgame."]
		tasks: [{
			id: "000000000000EF0F"
