			item: {id: "mmorpg:stone/2", Count: 2b}
		}]
	}, {
		id: "000000000000EF21"
		x: 10.0d
		y: -6.0d
		dependencies: ["000000000000EF12"]
		title: "The Continental Tournament"
		icon: {id: "soulland:cultivation_manual", Count: 1b}
		description: ["The Continental Tournament generates naturally in the world — find the Tournament Arena structure (5% spawn rate). Inside: a five-round bracket against eight novel-accurate academy teams, four opponents per round.", "Each team has martial souls, element-specific skills, and three-phase AI that activates Spirit Avatar mode at low health. Completion rewards scale through crystals up to the Godly Zhuge Crossbow and Buddha\'s Fury Tang Lotus. The tournament is the highest-density combat challenge Soul Land offers outside of the Divine Inheritance Trials."]
		tasks: [{
			id: "000000000000EF22"
			type: "checkmark"
			title: "Find the Tournament Arena and complete the Continental Tournament"
		}]
