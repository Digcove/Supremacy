		y: -4.0d
		dependencies: ["000000000000EF01"]
		title: "The Deep Form"
		icon: {id: "soulland:blue_silver_emperor_essence", Count: 1b}
		description: ["At Soul Power 60, Tier 2 integration deepens. Chest armor manifests, head features emerge — horns, glowing runes, element-specific overlays that shift the entire silhouette. The form reads your martial soul archetype and scales accordingly.", "25 martial souls are supported with 75 custom textures. Seraph wings expand from 2 at T1 to 4 here. T3 is still ahead."]
		tasks: [{
			id: "000000000000EF05"
			type: "checkmark"
			title: "Reach Soul Power 60 and observe T2 Martial Soul form [V]"
		}]
		rewards: [{
