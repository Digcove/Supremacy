		rewards: [{
			id: "000000000000A02B"
			type: "item"
			item: {id: "mmorpg:currency/orb_of_quality", Count: 1b}
		}]
	}, {
		id: "000000000000A02C"
		x: 4.0d
		y: -2.0d
		dependencies: ["000000000000A029"]
		title: "The Forging Table"
		icon: {id: "soulland:forging_table", Count: 1b}
		description: ["The Forging Table is the Soul Land equivalent of the Tinkers' Tool Forge — everything in the mod's crafting system runs through it. Weapons, armor, cultivation items, pills, the Spirit Detector.", "Build it from Spirit Iron and wood planks. Once placed, check JEI under the Forging Table tab for the full recipe list. There are a lot of recipes. Start with the tools."]
		tasks: [{
			id: "000000000000A02D"
			type: "item"
			item: {id: "soulland:forging_table", Count: 1b}
		}]
		rewards: [{
