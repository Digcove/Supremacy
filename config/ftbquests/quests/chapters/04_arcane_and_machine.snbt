			item: {id: "minecraft:leather", Count: 8b}
		}]
	}, {
		id: "000000000000C00A"
		x: 6.0d
		y: 0.0d
		dependencies: ["000000000000C007"]
		title: "The Archmage"
		icon: {id: "ars_nouveau:archmage_spellbook", Count: 1b}
		description: ["The Archmage Spellbook is the final tier — more spell slots, longer chains, and access to the most powerful glyphs in the mod. Spells that were three separate keybinds collapse into one.", "Craft it at the Enchanting Apparatus. This is the top of the Ars Nouveau progression. Everything after this is about what you build with it."]
		tasks: [{
