			type: "item"
			item: {id: "minecraft:enchanted_book", Count: 1b}
		}]
	}, {
		id: "000000000000C007"
		x: 4.0d
		y: 0.0d
		dependencies: ["000000000000C004"]
		title: "The Drygmy"
		icon: {id: "ars_nouveau:drygmy_charm", Count: 1b}
		description: ["A Drygmy is a mob-drop familiar. Summon one near a pen of passive mobs and it will generate their drops over time — wool, leather, feathers, raw meat — without killing anything. It runs on Source.", "Build the Drygmy Charm at the Enchanting Apparatus. Summon it, give it a Whirlisprig Flower to bond it to the area, and put a chest nearby for the output. This is your first passive mob farm."]
		tasks: [{
			id: "000000000000C008"
