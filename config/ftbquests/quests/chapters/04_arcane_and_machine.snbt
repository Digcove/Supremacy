		y: 2.0d
		dependencies: ["000000000000C00D"]
		title: "The Arm"
		icon: {id: "create:mechanical_arm", Count: 1b}
		description: ["The Mechanical Arm is Create's automation backbone — it reaches between machines, belts, and chests and moves items between them on a schedule. One Arm can replace a dozen item pipes if you set it up right.", "Assign input and output targets by right-clicking each one while holding the Arm. It reads your configuration and just runs."]
		tasks: [{
			id: "000000000000C011"
			type: "item"
			item: {id: "create:mechanical_arm", Count: 1b}
