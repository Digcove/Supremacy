	quests: [{
		id: "000000000000C019"
		x: -2.0d
		y: 0.0d
		title: "The Worn Notebook"
		icon: {id: "ars_nouveau:worn_notebook", Count: 1b}
		description: ["The Worn Notebook is your Ars Nouveau reference guide. It covers the spell grammar system (Form → Effect → Augment), Source generation, familiar summoning, and all glyph recipes.", "You won't have it in your inventory at spawn — find it by crafting: one Book plus one Mana Gem (Source Gem). Read it before you start assembling spells. The glyph system is unintuitive until you understand the grammar."]
		tasks: [{
			id: "000000000000C01A"
			type: "checkmark"
			title: "Craft and read the Worn Notebook"
		}]
		rewards: [{
			id: "000000000000C01B"
			type: "item"
			item: {id: "ars_nouveau:source_gem", Count: 4b}
		}]
	}, {
		id: "000000000000C01C"
		x: 0.0d
		y: -2.0d
		title: "On the Dynamics of Integration"
		icon: {id: "ars_creo:book", Count: 1b}
		description: ["Ars Creo bridges Ars Nouveau and Create — it adds spell glyphs that interact with rotational mechanics and Create structures, and Create blocks that respond to Source input.", "The guidebook 'On the Dynamics of Integration' explains every cross-mod mechanic. Craft it once you have both a Source infrastructure and working rotational power. The integration opens up late-game automation options that neither mod offers alone."]
		tasks: [{
			id: "000000000000C01D"
			type: "checkmark"
			title: "Obtain and read On the Dynamics of Integration (Ars Creo guidebook)"
		}]
		rewards: [{
			id: "000000000000C01E"
			type: "item"
			item: {id: "create:brass_ingot", Count: 4b}
		}]
	}, {
		id: "000000000000C001"
		x: 0.0d
		y: 0.0d
		title: "Source in Motion"
		icon: {id: "ars_nouveau:relay", Count: 1b}
		description: ["A Source Relay pulls from nearby Source Jars and distributes to other Jars or Ars machines across a wider range. Once your base has more than one Ars structure, you need a relay network or you'll be hand-filling jars forever.", "Place one between your Source Berry field and your Scribes Table. Let it run."]
		tasks: [{
			id: "000000000000C002"
			type: "item"
			item: {id: "ars_nouveau:relay", Count: 1b}
		}]
		rewards: [{
			id: "000000000000C003"
			type: "item"
			item: {id: "ars_nouveau:source_gem", Count: 8b}
		}]
	}, {
		id: "000000000000C004"
		x: 2.0d
		y: 0.0d
		dependencies: ["000000000000C001"]
		title: "The Enchanting Apparatus"
		icon: {id: "ars_nouveau:enchanting_apparatus", Count: 1b}
		description: ["The Enchanting Apparatus is a Source-powered enchanting altar that produces specific enchantments using reagent items instead of levels. You dictate the result. No more fishing for Silk Touch from a vanilla table.", "Surround it with Arcane Pedestals holding reagents, drop the item in the center, and consume Source. Check JEI for what each enchantment requires."]
		tasks: [{
			id: "000000000000C005"
			type: "item"
			item: {id: "ars_nouveau:enchanting_apparatus", Count: 1b}
		}]
		rewards: [{
