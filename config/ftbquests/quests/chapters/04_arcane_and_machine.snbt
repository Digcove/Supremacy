		id: "000000000000C00D"
		x: 0.0d
		y: 2.0d
		title: "The Crafter"
		icon: {id: "create:mechanical_crafter", Count: 1b}
		description: ["The Mechanical Crafter is a grid of rotating blocks that craft recipes under rotational power. Arrange them into the shape of a crafting recipe, supply the ingredients, and they assemble the output automatically.", "This is where Create becomes an automated factory instead of a collection of machines. Every recipe that was a crafting table can now run without you."]
		tasks: [{
			id: "000000000000C00E"
			type: "item"
