	}, {
		id: "0000000000003026"
		x: 20.0d
		y: -1.0d
		dependencies: ["0000000000003020"]
		exclusive_to: ["0000000000003029", "000000000000302C"]
		title: "Path of the Sentinel"
		icon: {id: "mmorpg:currency/force_soul_tag_armor_stat", Count: 1b}
		description: ["The Sentinel path converts your armor into heavy plate — the highest physical defense archetype available. Sentinels absorb punishment, hold ground, and scale into tanking, boss fights, and front-line engagements where staying alive longer is the primary objective.", "Apply one Force Soul Tag: Armor to each of your four armor pieces. The tag permanently marks each slot for plate-class stat rolls on future upgrade tiers. This choice cannot be undone on the current set."]
		tasks: [{
			id: "0000000000003027"
			type: "checkmark"
			title: "Choose the Sentinel Path — commit to plate defense"
		}]
		rewards: [{
			id: "0000000000003028"
			type: "item"
			item: {id: "mmorpg:currency/force_soul_tag_armor_stat", Count: 4b}
		}]
	}, {
		id: "0000000000003029"
		x: 20.0d
		y: 0.0d
		dependencies: ["0000000000003020"]
		exclusive_to: ["0000000000003026", "000000000000302C"]
		title: "Path of the Shade"
		icon: {id: "mmorpg:currency/force_soul_tag_dodge_stat", Count: 1b}
		description: ["The Shade path builds your defense around evasion rather than absorption. Shades survive because hits miss, not because hits are reduced. This path rewards mobile playstyles, positioning, and weapon types from Spartan Weaponry that favor quick strikes over sustained trading.", "Apply one Force Soul Tag: Dodge to each of your four armor pieces to commit. This path scales best in the mid-game when dodge stacking becomes meaningful and enemies have predictable attack patterns."]
		tasks: [{
			id: "000000000000302A"
			type: "checkmark"
			title: "Choose the Shade Path — commit to evasion and mobility"
		}]
		rewards: [{
			id: "000000000000302B"
			type: "item"
			item: {id: "mmorpg:currency/force_soul_tag_dodge_stat", Count: 4b}
		}]
	}, {
		id: "000000000000302C"
		x: 20.0d
		y: 1.0d
		dependencies: ["0000000000003020"]
		exclusive_to: ["0000000000003026", "0000000000003029"]
		title: "Path of the Arcanist"
		icon: {id: "mmorpg:currency/force_soul_tag_magic_shield_stat", Count: 1b}
		description: ["The Arcanist path replaces physical defense with a regenerating Magic Shield — a secondary health pool that absorbs damage before your health bar takes a hit. Arcanists deal damage through spells, Iron's Spells abilities, and Ars Nouveau magic, and their defense scales with the same magical investment.", "Apply one Force Soul Tag: Magic Shield to each of your four armor pieces to commit. This path becomes significantly more powerful once you have access to a proper spellbook in Act II."]
		tasks: [{
			id: "000000000000302D"
			type: "checkmark"
			title: "Choose the Arcanist Path — commit to magic shield and spellcasting"
		}]
		rewards: [{
