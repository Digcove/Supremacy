			type: "item"
			item: {id: "mmorpg:currency/force_soul_tag_magic_shield_stat", Count: 4b}
		}]
	}, {
		id: "000000000000300A"
		x: 6.0d
		y: -2.0d
		dependencies: ["0000000000003007"]
		title: "Four Legs, More Ground"
		icon: {id: "minecraft:saddle", Count: 1b}
		description: ["A horse is the fastest way to cover ground before you have trains, waystones, or flight. They can also wear armor and carry you over terrain that slows foot travel considerably.", "Wheat grows from seeds dropped by tall grass — plant a small farm early. Apples drop from oak leaf blocks when you break them. Both items are obtainable without any special equipment."]
		tasks: [{
