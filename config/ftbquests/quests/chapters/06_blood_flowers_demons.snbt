		y: 2.0d
		dependencies: ["000000000000E018"]
		title: "Tier 2: Blood Runes"
		icon: {id: "bloodmagic:blood_rune", Count: 1b}
		description: ["The Blood Rune is the base upgrade component. Place eight of them around the outside of your altar to reach Tier 2. T2 unlocks a larger LP capacity and lets you craft the first Blood Orb — a portable Soul Network extension.", "The Weak Blood Orb holds 5,000 LP. Carry it. It dies so you don't have to run back to the altar."]
		tasks: [{
			id: "0000000000230002"
			type: "item"
