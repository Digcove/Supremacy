		x: 12.0d
		y: 4.0d
		dependencies: ["000000000023000D"]
		title: "Demonic Will"
		icon: {id: "bloodmagic:sentient_sword", Count: 1b}
		description: ["Demonic Will is a second resource collected by killing mobs while carrying a Tartaric Gem. The Petty Tartaric Gem holds a small amount — upgrade through Lesser, Common, and Grand tiers as you kill more.", "Enough Will lets you craft a Sentient Sword — it consumes Will instead of durability, deals bonus damage scaled to Will capacity, and transforms based on your current Will level."]
		tasks: [{
			id: "0000000000230014"
			type: "checkmark"
			title: "Fill a Petty Tartaric Gem with Demonic Will by slaying mobs"
