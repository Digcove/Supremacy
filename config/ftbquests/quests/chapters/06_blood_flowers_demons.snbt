	}, {
		id: "000000000000E01B"
		x: 0.0d
		y: -2.0d
		title: "Otherworld Tree"
		icon: {id: "occultism:otherworld_sapling_natural", Count: 1b}
		description: ["Occultism's crafting material — Otherstone and Otherwood — comes from Otherworld Trees, which generate in specific biomes. Find one or grow one from an Otherworld Sapling. Harvest it for the resources.", "You can see Otherworld Trees by drinking a Potion of Third Eye. Without it, they appear as regular trees — there but invisible in their true form."]
		tasks: [{
			id: "000000000000E01C"
			type: "item"
			item: {id: "occultism:otherstone", Count: 1b}
