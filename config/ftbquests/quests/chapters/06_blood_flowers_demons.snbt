			type: "item"
			item: {id: "bloodmagic:weak_blood_orb", Count: 1b}
		}]
	}, {
		id: "0000000000230004"
		x: 8.0d
		y: 2.0d
		dependencies: ["0000000000230001"]
		title: "Bound Tools"
		icon: {id: "bloodmagic:bound_pickaxe", Count: 1b}
		description: ["Bound Tools work like the Bound Blade — infinite durability in exchange for Life Essence per use. The Bound Pickaxe becomes Fortune III when your Soul Network is full and Silk Touch when it's low.", "They're not free — keep your network fed or the tools go dormant. But a full Soul Network makes them faster and better-enchanted than almost anything else at this tier."]
		tasks: [{
			id: "0000000000230005"
			type: "item"
			item: {id: "bloodmagic:bound_pickaxe", Count: 1b}
		}]
		rewards: [{
