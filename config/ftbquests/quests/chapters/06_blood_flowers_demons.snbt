		y: 2.0d
		dependencies: ["000000000023000D"]
		title: "Living Armor"
		icon: {id: "bloodmagic:living_chestplate", Count: 1b}
		description: ["Living Armor is Blood Magic's endgame armor. Instead of enchantments it runs Upgrades — each slot consumes LP over time to maintain its effect. Flight, fire resistance, step assist, fall immunity — they stack and can be toggled.", "Pieces are crafted at the altar from Living Infused String. Once you have a full set, the upgrade system is where the real power lives."]
		tasks: [{
			id: "0000000000230011"
			type: "checkmark"
			title: "Craft a full set of Living Armor at the Blood Altar"
