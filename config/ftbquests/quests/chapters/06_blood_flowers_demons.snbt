		}, {
			id: "000000000000E00E"
			type: "item"
			item: {id: "botania:rune_water", Count: 1b}
		}]
	}, {
		id: "000000000000E00F"
		x: 8.0d
		y: 0.0d
		dependencies: ["000000000000E00B"]
		title: "Manasteel"
		icon: {id: "botania:manasteel_ingot", Count: 1b}
		description: ["Manasteel is Botania's primary metal. Drop Spirit Steel Ingots into a Mana Pool with enough Mana and they convert. This is the gate — Soul Land progression feeds directly into Botania's material line.", "Eight Manasteel Ingots make Manasteel armor. Manasteel also feeds into Terrasteel and eventually Elementium. Get comfortable with this pool."]
		tasks: [{
			id: "000000000000E010"
			type: "item"
			item: {id: "botania:manasteel_ingot", Count: 1b}
			count: 8L
