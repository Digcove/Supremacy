			type: "item"
			item: {id: "bloodmagic:life_essence_vial", Count: 4b}
		}]
	}, {
		id: "000000000000E015"
		x: 2.0d
		y: 2.0d
		dependencies: ["000000000000E012"]
		title: "Bound by Blood"
		icon: {id: "bloodmagic:bound_blade", Count: 1b}
		description: ["The Bound Blade is a weapon that grows stronger as your Soul Network fills. It doesn't consume durability — it consumes Life Essence instead. Keep your health high and your network full and it will always be sharp.", "Craft it at the Blood Altar. This is your first Blood Magic weapon. It won't be your last."]
		tasks: [{
			id: "000000000000E016"
			type: "item"
			item: {id: "bloodmagic:bound_blade", Count: 1b}
		}]
		rewards: [{
			id: "000000000000E017"
			type: "item"
			item: {id: "bloodmagic:life_essence_vial", Count: 8b}
		}]
	}, {
		id: "000000000000E018"
		x: 4.0d
		y: 2.0d
		dependencies: ["000000000000E015"]
		title: "Sigil of the Blood Lamp"
		icon: {id: "bloodmagic:sigil_blood_light", Count: 1b}
		description: ["Sigils are Blood Magic's utility tools — consumable or persistent effects powered by your Soul Network. The Sigil of the Blood Lamp places a sourceless light wherever you click. Free lighting that doesn't require placing torches.", "There are sigils for water, fire resistance, air, and more. The Sigil of the Green Grove keeps nearby crops watered. Build what you need."]
		tasks: [{
			id: "000000000000E019"
			type: "item"
