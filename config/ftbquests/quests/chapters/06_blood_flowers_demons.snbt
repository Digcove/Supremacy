		x: 4.0d
		y: -2.0d
		dependencies: ["000000000000E01E"]
		title: "First Summon"
		icon: {id: "occultism:foliot", Count: 1b}
		description: ["Perform the Ritual of Summoning: Foliot. A Foliot is the lowest rank of demon — weak but useful. Bind it to a task: hauling items, managing a crusher, operating a storage interface. It will work indefinitely without complaining.", "Occultism's endgame is a network of demons doing your work. Start with one."]
		tasks: [{
			id: "000000000000E022"
			type: "checkmark"
			title: "Complete the Ritual of Summoning: Foliot and bind it to a task"
		}]
		rewards: [{
			id: "000000000000E023"
			type: "item"
			item: {id: "occultism:spirit_attuned_gem", Count: 2b}
		}]
	}, {
		id: "000000000000E024"
		x: 6.0d
		y: -2.0d
		dependencies: ["000000000000E021"]
		title: "The Storage Actuator"
		icon: {id: "occultism:storage_actuator_base", Count: 1b}
		description: ["Occultism's Storage Actuator is a demon-powered storage system — a djinn bound to a storage matrix that can hold vastly more than any chest and sorts itself. It functions like Applied Energistics but runs on demon labor instead of power.", "It requires a higher-rank demon than the Foliot. Summon a Djinn through the appropriate ritual and bind it to the Actuator. This is mid-tier Occultism and worth the investment before you reach AE2."]
		tasks: [{
			id: "000000000000E025"
			type: "item"
			item: {id: "occultism:storage_actuator_base", Count: 1b}
		}]
		rewards: [{
