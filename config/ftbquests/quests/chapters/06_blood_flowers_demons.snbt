		y: 4.0d
		dependencies: ["0000000000230001"]
		title: "Utility Sigils"
		icon: {id: "bloodmagic:sigil_green_grove", Count: 1b}
		description: ["The Sigil of the Green Grove hydrates farmland and accelerates nearby crop growth — just hold it in your offhand. The Void Sigil deletes a bucket's worth of fluid on use. The Magnetism Sigil pulls item drops to you from range.", "Sigils cost LP per use, not durability. They're the cheapest sustained-utility option Blood Magic offers."]
		tasks: [{
			id: "0000000000230008"
			type: "item"
			item: {id: "bloodmagic:sigil_green_grove", Count: 1b}
		}]
