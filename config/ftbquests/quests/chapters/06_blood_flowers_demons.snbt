			item: {id: "botania:rune_water", Count: 1b}
		}]
	}, {
		id: "000000000000E00F"
		x: 8.0d
		y: 0.0d
		dependencies: ["000000000000E00B"]
		title: "Manasteel"
		icon: {id: "botania:manasteel_ingot", Count: 1b}
		description: ["Manasteel is Botania's primary metal. Drop Spirit Steel Ingots into a Mana Pool with enough Mana and they convert. This is the gate — Soul Land progression feeds directly into Botania's material line.", "Eight Manasteel Ingots make Manasteel armor. Manasteel also feeds into Terrasteel and eventually Elementium. Get comfortable with this pool."]
		tasks: [{
			id: "000000000000E010"
			type: "item"
			item: {id: "botania:manasteel_ingot", Count: 1b}
			count: 8L
		}]
		rewards: [{
			id: "000000000000E011"
			type: "item"
			item: {id: "soulland:spirit_steel_ingot", Count: 4b}
		}]
	}, {
		id: "000000000000E012"
		x: 0.0d
		y: 2.0d
		title: "The Blood Altar"
		icon: {id: "bloodmagic:blood_altar", Count: 1b}
		description: ["Blood Magic runs on life. The Blood Altar converts your health into Life Essence — a resource stored in your Soul Network that powers rituals, sigils, and the altar's own crafting.", "Build the Tier 1 Altar from stone bricks and a Blood Rune. Right-click it with a dagger. You'll take damage. That's the cost. Get used to it."]
		tasks: [{
			id: "000000000000E013"
			type: "item"
			item: {id: "bloodmagic:blood_altar", Count: 1b}
		}]
		rewards: [{
