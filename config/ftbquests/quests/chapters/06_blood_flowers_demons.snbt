		title: "The Pure Daisy"
		icon: {id: "botania:pure_daisy", Count: 1b}
		description: ["Botania begins with a flower. The Pure Daisy converts stone and wood into Livingrock and Livingwood — the base materials for almost everything in the mod.", "Place it on grass. Surround it with stone blocks. Wait. Check the Lexica Botania (right-click a bookshelf while holding a book) for the full recipe list — Botania explains itself if you read it."]
		tasks: [{
			id: "000000000000E002"
			type: "item"
			item: {id: "botania:livingrock", Count: 1b}
			count: 16L
		}]
		rewards: [{
			id: "000000000000E003"
			type: "item"
			item: {id: "botania:pure_daisy", Count: 2b}
		}]
	}, {
		id: "000000000000E004"
		x: 2.0d
		y: 0.0d
		dependencies: ["000000000000E001"]
		title: "The First Flower"
		icon: {id: "botania:daybloom", Count: 1b}
		description: ["Mana Generating flowers pull Mana from the environment and store it. The Daybloom generates from sunlight — slow but free. The Endoflame burns fuel — fast when fed, useless when empty.", "Plant several of each. You need a lot of Mana. The flowers make it. The Mana Spreader moves it. Start building both now."]
		tasks: [{
			id: "000000000000E005"
			type: "item"
			item: {id: "botania:daybloom", Count: 4b}
		}]
		rewards: [{
			id: "000000000000E006"
			type: "item"
			item: {id: "botania:endoflame", Count: 2b}
		}]
	}, {
		id: "000000000000E007"
		x: 4.0d
		y: 0.0d
		dependencies: ["000000000000E004"]
		title: "Mana Flow"
		icon: {id: "botania:mana_spreader", Count: 1b}
		description: ["The Mana Spreader is a beam cannon that moves Mana from a flower or pool to another pool. Point the Spreader at a Mana Pool, let it fill.", "Direction matters: a Spreader points where you right-click it. Hold a Wand of the Forest to redirect. Your entire Mana network is Spreaders pointed at Pools pointed at machines."]
		tasks: [{
			id: "000000000000E008"
			type: "item"
			item: {id: "botania:mana_spreader", Count: 1b}
		}, {
			id: "000000000000E009"
			type: "item"
			item: {id: "botania:mana_pool", Count: 1b}
		}]
		rewards: [{
			id: "000000000000E00A"
			type: "item"
			item: {id: "botania:mana_spreader", Count: 1b}
		}]
	}, {
		id: "000000000000E00B"
		x: 6.0d
		y: 0.0d
		dependencies: ["000000000000E007"]
		title: "The Runic Altar"
		icon: {id: "botania:runic_altar", Count: 1b}
		description: ["The Runic Altar crafts Runes — the fundamental components that all higher-tier Botania equipment requires. Place ingredients on the Altar, feed it Mana from a Spreader, and right-click with a Wand of the Forest to complete the craft.", "You need Runes for Manasteel tools, armor, and most of the meaningful Botania machines. Start with the elemental runes."]
		tasks: [{
			id: "000000000000E00C"
			type: "item"
			item: {id: "botania:runic_altar", Count: 1b}
		}]
		rewards: [{
			id: "000000000000E00D"
			type: "item"
