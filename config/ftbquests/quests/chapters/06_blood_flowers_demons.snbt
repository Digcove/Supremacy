			type: "item"
			item: {id: "soulland:spirit_steel_ingot", Count: 4b}
		}]
	}, {
		id: "000000000000E012"
		x: 0.0d
		y: 2.0d
		title: "The Blood Altar"
		icon: {id: "bloodmagic:blood_altar", Count: 1b}
		description: ["Blood Magic runs on life. The Blood Altar converts your health into Life Essence — a resource stored in your Soul Network that powers rituals, sigils, and the altar's own crafting.", "Build the Tier 1 Altar from stone bricks and a Blood Rune. Right-click it with a dagger. You'll take damage. That's the cost. Get used to it."]
		tasks: [{
			id: "000000000000E013"
			type: "item"
			item: {id: "bloodmagic:blood_altar", Count: 1b}
		}]
		rewards: [{
