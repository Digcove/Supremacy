			x: 3.0d
			y: -15.0d
		}
		{
			dependencies: ["AE01000000000003"]
			description: ["ME Energy Cells buffer network power between the generator and the Controller. The standard Energy Cell stores 200,000 AE; Dense Energy Cell stores 1,600,000 AE. MEGACells adds the Mega Energy Cell for enormous buffer capacity at endgame. A Dense Energy Cell buffer prevents network dropout during brief generator interruptions — one Dense Cell per network is the baseline minimum. The network drops all operations instantly if the Controller loses power with no buffer in place, so size the buffer against your longest expected generator gap."]
			id: "AE01000000000020"
