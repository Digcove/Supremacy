			title: "Processors"
			x: 3.0d
			y: -7.5d
		}
		{
			dependencies: [
				"AE01000000000008"
				"AE01000000000010"
			]
			description: ["Cell Components are the media inside AE2 storage cells — each tier (1k, 4k, 16k, 64k, 256k) stores more bytes per component at higher material cost. A 1k component stores 1,024 bytes; 256k stores 262,144. A Cell Housing (item or fluid type) completes the cell. Each cell in a Drive carries a 63-type limit by default regardless of tier — use a Cell Workbench to partition cells to specific items and prevent miscellaneous drops consuming type slots. Run 4k and 16k as your primary storage tier; 64k and 256k for high-volume bulk commodities."]
			id: "AE01000000000011"
			rewards: [{
				count: 4
				id: "AE03000000000011"
				item: "ae2:cell_component_4k"
				type: "item"
			}]
