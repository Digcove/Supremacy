	quests: [
		{
			description: ["Applied Energistics 2 converts item storage into a digital network accessible from anywhere through ME Terminals. Items stored in ME Cells are indexed and searchable regardless of where the physical cells sit on the network. The ME Controller is the mandatory hub — exactly one per logical network, connected to every other component directly or via cable. Power is delivered through an ME Energy Acceptor block fed by any power source, or natively from GTCEu cables at higher tiers. Every other AE2 block is optional; the minimum viable network is a Controller, a Drive, a Cell, and a Terminal. Everything else is throughput and reach."]
			id: "AE01000000000001"
			rewards: [{
				count: 2
				id: "AE03000000000001"
				item: "mmorpg:stone/1"
				type: "item"
			}]
			shape: "diamond"
			size: 1.5d
			tasks: [{
				id: "AE02000000000001"
				title: "Read the ME Network Guide"
				type: "checkmark"
			}]
			title: "The ME Network"
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["AE01000000000001"]
			description: ["Certus Quartz Crystals grow from Certus Quartz Buds on Skystone and Charged Skystone found in meteorite craters scattered across the overworld. Buds grow through four stages and drop a crystal when fully grown and broken. Accelerate production by placing Certus Quartz Seeds in water — each seed matures into a crystal and can be harvested without destroying the water block. Certus consumption across the full AE2 progression is heavy and never plateaus; establish a growing array early and expand it before you think you need to."]
			id: "AE01000000000002"
			rewards: [{
				count: 8
				id: "AE03000000000002"
				item: "ae2:certus_quartz_crystal"
				type: "item"
			}]
			tasks: [{
				id: "AE02000000000002"
				item: "ae2:certus_quartz_crystal"
				type: "item"
			}]
			title: "Certus Quartz"
			x: -3.0d
			y: -2.5d
		}
		{
			dependencies: ["AE01000000000001"]
			description: ["The ME Controller is the hub every AE2 network requires. Place it first, then connect cables and components to it directly or through cable runs. Connecting two ME Controllers merges or splits the network depending on orientation — maintain exactly one per logical network. The Controller requires continuous power; if power drops, all terminals go offline and stored item access is suspended until power is restored. Establish reliable power delivery to the Controller before adding any other network components."]
			id: "AE01000000000003"
			rewards: [{
				count: 2
				id: "AE03000000000003"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
			tasks: [{
				id: "AE02000000000003"
				item: "ae2:controller"
				type: "item"
			}]
			title: "ME Controller"
			x: 0.0d
			y: -2.5d
		}
		{
			dependencies: ["AE01000000000001"]
			description: ["The ME Inscriber presses printed circuit components using engraved press dies found inside Skystone Meteorite chests in the overworld — check for meteor craters and dig to find the chest. Four presses exist: Logic, Calculation, Engineering, and Silicon. Each press occupies the top or bottom slot of an Inscriber; the material to press goes in the center slot. Run multiple Inscribers in parallel — processor production is the primary throughput constraint throughout all of AE2 progression, and a single machine stalls the entire downstream build."]
			id: "AE01000000000004"
			rewards: [{
				count: 2
				id: "AE03000000000004"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
			tasks: [{
				id: "AE02000000000004"
				item: "ae2:inscriber"
				type: "item"
			}]
			title: "Inscriber"
			x: 3.0d
			y: -2.5d
		}
		{
			dependencies: ["AE01000000000002"]
			description: ["The ME Charger block charges Certus Quartz Crystals by consuming power. Place a raw crystal in the Charger and supply it with any power source — it outputs a Charged Certus Quartz Crystal. Charged crystals discharge over time outside the Charger, so use them promptly after charging or keep them inside until needed. The Charger consumes minimal power and can be fed from any early-game generator. Build it before attempting Fluix synthesis — charged certus is a required reagent."]
			id: "AE01000000000005"
			rewards: [{
				count: 4
				id: "AE03000000000005"
				item: "ae2:charged_certus_quartz_crystal"
				type: "item"
			}]
			tasks: [
				{
					id: "AE02000000000005"
					item: "ae2:charger"
					type: "item"
				}
				{
					id: "AE02000000000006"
					item: "ae2:charged_certus_quartz_crystal"
					type: "item"
				}
			]
			title: "ME Charger"
			x: -3.0d
			y: -5.0d
		}
		{
			dependencies: ["AE01000000000003"]
			description: ["The ME Drive accepts up to ten ME Storage Cells and exposes all of their contents to the network. Each Drive holds any mix of item and fluid cells regardless of tier. Place the Drive adjacent to the Controller or connect via cable — connection order does not matter. Build a second Drive before the first fills; migrating cells to overflow storage under active load is inconvenient, and the second Drive costs almost nothing relative to the cells it will hold."]
			id: "AE01000000000006"
			rewards: [{
				count: 1
				id: "AE03000000000006"
				item: "ae2:1k_item_storage_cell"
				type: "item"
			}]
			tasks: [{
				id: "AE02000000000007"
				item: "ae2:drive"
				type: "item"
			}]
			title: "ME Drive"
			x: 0.0d
			y: -5.0d
		}
		{
			dependencies: ["AE01000000000004"]
			description: ["Each press produces one printed component type. Logic Press: iron ingot → Printed Logic Processor. Calculation Press: pure certus quartz crystal → Printed Calculation Processor. Engineering Press: gold ingot → Printed Engineering Processor. Silicon Press: sand or silicon dust → Printed Silicon. All four types are required to assemble the final processors. Automate Inscriber input and output with hoppers or import/export buses as soon as possible — manually cycling four machines is a consistent production stall."]
			id: "AE01000000000007"
			rewards: [{
				count: 2
				id: "AE03000000000007"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
			tasks: [
