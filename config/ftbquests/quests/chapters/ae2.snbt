			x: -3.0d
			y: -10.0d
		}
		{
			dependencies: [
				"AE01000000000009"
				"AE01000000000010"
			]
			description: ["The ME Terminal displays all items stored across the network's Drive array, searchable and sortable in real time. The Crafting Terminal adds an integrated 3x3 crafting grid that auto-pulls ingredients from network storage — items drawn for crafting are debited from the network immediately. Both require one channel on the connected cable segment. Use the Crafting Terminal as the primary interaction point; the plain Terminal is useful for read-only secondary access where the crafting grid is not needed and channel budget is tight."]
			id: "AE01000000000012"
			rewards: [{
				count: 2
				id: "AE03000000000012"
