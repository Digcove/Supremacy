					type: "item"
				}
			]
			title: "ME Terminals"
			x: 0.0d
			y: -10.0d
		}
		{
			dependencies: [
				"AE01000000000010"
				"AE01000000000006"
			]
			description: ["Blank Patterns are the base medium for encoding autocrafting recipes. Insert one into the Pattern Encoding Terminal and program it with a crafting, processing, or smelt recipe — the pattern stores exactly which items go in and which come out. Encoded patterns are placed in Pattern Providers adjacent to Molecular Assemblers or GTCEu machines, instructing the network how to produce items on demand. Keep a full stack of Blank Patterns on hand; complex autocrafting trees require many patterns, and modifying a recipe means re-encoding from scratch."]
			id: "AE01000000000013"
			rewards: [{
				count: 16
				id: "AE03000000000013"
				item: "ae2:blank_pattern"
				type: "item"
			}]
			tasks: [{
				id: "AE02000000000025"
				item: "ae2:blank_pattern"
				type: "item"
			}]
			title: "Blank Patterns"
			x: 3.0d
			y: -10.0d
		}
		{
			dependencies: ["AE01000000000011"]
			description: ["ME Storage Cells are assembled from a Cell Component and a Cell Housing — Item Cell Housing for items, Fluid Cell Housing for fluids. Install completed cells in ME Drives to expose their contents to the network. Partition important bulk cells using a Cell Workbench to reserve specific item types and prevent type-slot exhaustion from random drops. Dual Cell Housing (from Expanded AE) holds both item and fluid types in a single cell — useful for machines that output both and reduces Drive slot consumption at scale."]
			id: "AE01000000000014"
			rewards: [{
				count: 2
