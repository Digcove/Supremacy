				{
					id: "AE02000000000015"
					item: "ae2:fluix_covered_dense_cable"
					type: "item"
				}
			]
			title: "ME Cables"
			x: 0.0d
			y: -7.5d
		}
		{
			dependencies: [
				"AE01000000000007"
				"AE01000000000008"
			]
			description: ["The three processor types are assembled in a fifth Inscriber run: each printed component is combined with Printed Silicon and Fluix Crystal. Logic Processors go into basic AE2 components; Calculation Processors into storage cells, crafting units, and pattern providers; Engineering Processors into advanced devices including Dense Energy Cells and Quantum Bridges. Processor velocity determines the pace of all downstream AE2 construction. Five Inscribers running simultaneously — one per printed type plus one for final assembly — is the practical minimum for smooth early expansion."]
			id: "AE01000000000010"
			rewards: [{
				count: 4
