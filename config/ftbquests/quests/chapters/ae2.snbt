			]
			title: "Storage Cells"
			x: -3.0d
			y: -12.5d
		}
		{
			dependencies: ["AE01000000000012"]
			description: ["The Crafting CPU is a multiblock assembled from Crafting Units, Crafting Storage blocks, Crafting Accelerators, and a Crafting Monitor. The CPU processes one autocrafting job at a time — Crafting Storage tier determines how complex a tree it can plan simultaneously; Crafting Accelerators reduce ticks between ingredient dispensing steps. Build at minimum a 3x3 structure with a 16k or 64k Crafting Storage and four to eight Accelerators. Undersized CPUs visibly stall on multi-step GTCEu processing chains that require many intermediate crafting passes."]
			id: "AE01000000000015"
			rewards: [{
				count: 2
				id: "AE03000000000015"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
			tasks: [{
				id: "AE02000000000029"
				item: "ae2:crafting_unit"
				type: "item"
			}]
			title: "Crafting CPU"
			x: 0.0d
			y: -12.5d
		}
		{
			dependencies: ["AE01000000000013"]
			description: ["The Pattern Provider pushes encoded pattern ingredients into adjacent inventories or machines. For item crafting, pair it with a Molecular Assembler; for GTCEu processing recipes, pair it with a GT ME Input Bus, which bypasses the need for assemblers entirely. Each Provider slot holds one pattern; swap patterns to change what a machine can produce on demand. The Ex Pattern Provider (from ExtendedAE) extends this with multiple simultaneous output channels and improved throughput — use it for high-volume production lines that exhaust the standard Provider's single-slot dispatch."]
			id: "AE01000000000016"
			rewards: [{
				count: 2
				id: "AE03000000000016"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
			tasks: [
				{
					id: "AE02000000000030"
					item: "ae2:pattern_provider"
					type: "item"
				}
				{
					id: "AE02000000000031"
					item: "expatternprovider:ex_pattern_provider"
					type: "item"
				}
			]
			title: "Pattern Providers"
			x: 3.0d
			y: -12.5d
		}
		{
			dependencies: [
				"AE01000000000014"
				"AE01000000000009"
			]
			description: ["The Import Bus pulls items from adjacent inventories into the network automatically. The Export Bus pushes items from the network into adjacent inventories. Both require one channel and a filter — configure filters to restrict which items each bus handles. An unfiltered Import Bus on a machine output chest pulls everything, flooding the network with intermediate products and waste. An unfiltered Export Bus does nothing. Always set filters before placing either bus adjacent to an active machine buffer. The Ex Import and Ex Export Buses from ExtendedAE support higher throughput and expanded filter options for high-density machine clusters."]
			id: "AE01000000000017"
			rewards: [{
				count: 2
				id: "AE03000000000017"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
