			y: -15.0d
		}
		{
			dependencies: ["AE01000000000016"]
			description: ["The Molecular Assembler accepts ingredient pushes from an adjacent Pattern Provider and assembles them into finished items using an internal crafting grid. Each Assembler handles one pattern at a time from one Provider. For high throughput, arrange multiple Provider-Assembler pairs in a grid — the CPU dispatches to any available Assembler in parallel. The Assembler Matrix (from ExtendedAE) replaces the traditional grid arrangement with a multiblock structure that scales throughput to thousands of operations per second; build it when Molecular Assembler arrays become the bottleneck."]
			id: "AE01000000000019"
