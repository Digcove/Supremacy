			type: "item"
			item: {id: "gtceu:uhv_machine_hull", Count: 2b}
		}]
	}, {
		id: "0000000000040019"
		x: 12.0d
		y: 0.0d
		dependencies: ["0000000000040016"]
		title: "Tier 5 — Fusion Forge"
		icon: {id: "mmorpg:stone/4", Count: 1b}
		description: ["The fifth Orb Forge station. The Map Boss Drop is its combat gate — a specific drop from the endgame Atlas map bosses accessed through repeated high-tier map runs. The Fusion Forge operates at fusion-reaction precision and crafts the most dangerous currency in the system.", "The Orb of Runic Invocation has a 25% item destruction chance built into the currency itself — not into the recipe, not into the machine, into the orb. The Orb of Rebirth randomizes every affix to mythic-tier simultaneously. The two Rebirth orbs don't reroll affix values — they replace which affixes exist. These are irreversible. Use deliberately.", "The Fusion Forge is one of the six lower-tier Orb Forge stations. All six machines can produce their orbs throughout your progression. The Orb Forge in the next chapter supersedes them all — running every recipe at a quarter of the time."]
		tasks: [{
			id: "000000000004001A"
			type: "item"
			item: {id: "kubejs:map_boss_drop", Count: 1b}
		}, {
			id: "000000000004001B"
			type: "checkmark"
			title: "Assemble the Fusion Forge"
		}]
		rewards: [{
			id: "000000000004001C"
			type: "item"
			item: {id: "mmorpg:stone/4", Count: 2b}
		}]
	}, {
		id: "000000000004001D"
		x: 14.0d
		y: -1.5d
		dependencies: ["0000000000040019"]
		title: "Orb of Runic Invocation"
		icon: {id: "mmorpg:currency/common_to_runed", Count: 1b}
		description: ["Forge an Orb of Runic Invocation in the Fusion Forge. Transforms a Common-quality item into a Runed item — but the currency itself carries a 25% chance to destroy the item instead. That destroy chance is native and permanent. Gate: Legendary Stone + Map Boss Drop + Helium Plasma Bucket."]
