		}
		{
			dependencies: ["5C5C000000000004"]
			description: ["Sidearms are the entry tier of the arsenal: pistols and revolvers like the M1911, Glock 17, Desert Eagle, and Rhino 357. Their recipes are built on &eHV-tier&r materials — stainless steel plates and HV components. Stainless steel is mixed from iron, nickel, manganese, and chrome dusts, then blasted into ingots in the Electric Blast Furnace. A sidearm will not replace your melee build, but it is always in your pocket, always loaded, and it teaches the handling fundamentals every later platform shares."]
			icon: {
				Count: 1
				id: "tacz:modern_kinetic_gun"
				tag: {
					GunId: "tacz:deagle"
				}
			}
