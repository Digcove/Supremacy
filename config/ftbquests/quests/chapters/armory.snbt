		{
			dependencies: ["5C5C000000000004"]
			description: ["A gun without ammunition is an expensive club. Every weapon feeds on a specific caliber — check the gun's tooltip — and every caliber is crafted at the Gun Smith Table's ammo tab. In this pack ammunition inputs have been shifted toward GregTech &ebrass&r: copper and zinc mixed and alloyed into cheap, endlessly reproducible casing stock. Ammo is deliberately cheap relative to the guns themselves; scarcity gates the weapon, not the trigger. Stock your table's chest with brass and gunpowder and craft in bulk."]
			icon: {
				Count: 1
				id: "tacz:ammo"
				tag: {
					AmmoId: "tacz:9mm"
				}
			}
