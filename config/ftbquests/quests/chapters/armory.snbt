		{
			dependencies: ["5C5C000000000003"]
			description: ["Firearms handle differently from anything else in your hotbar. Fire with left click. Hold right click to aim down sights — accuracy and recoil control improve dramatically while aiming. Reload with &eR&r; rounds are pulled from matching ammo in your inventory or an ammo box. Many guns carry multiple fire modes — semi, burst, full-auto — cycled with the fire-select key. The gun HUD by your hotbar shows the loaded round count and current fire mode. Every key is rebindable under Options, Controls, in the TACZ category — check that menu once before your first fight, not during it."]
			icon: "minecraft:book"
			id: "5C5C000000000004"
			rewards: [
				{
					auto: "enabled"
					command: "/mine_and_slash give xp_times_lvl @p 150"
