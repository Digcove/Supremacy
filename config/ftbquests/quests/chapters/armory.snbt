			title: "The Terrasteel Toll"
			x: 0.0d
			y: 2.5d
		}
		{
			dependencies: ["5C5C000000000002"]
			description: ["The Gun Smith Table is the single crafting station for every gun, every round of ammunition, and every attachment you will ever make. Open it and browse by category tab — each entry lists its full material cost before you commit. In this pack those costs have been rebuilt around GregTech: plates, motors, and higher-tier components replace the default scrap-metal recipes, so the table doubles as a shopping list for your GT production lines. Place it next to your material storage; you will be back here constantly."]
			id: "5C5C000000000003"
			rewards: [
				{
					auto: "enabled"
					command: "/mine_and_slash give xp_times_lvl @p 150"
