	quest_links: [ ]
	quests: [
		{
			description: ["Mine and Slash melee reads your character sheet — every point of strength, every affix, every level multiplies your swing. Firearms do not read it at all. A gun's damage is flat: the same at level 1 as at level 100, gated behind GregTech materials instead of character progression. That is the design. Late-game bosses stack armor and health pools that punish short melee windows, and flying or burrowing targets never give you one. Sustained, ranged, flat DPS closes those fights. Guns are the last weapon class this pack unlocks, and they are worth the wait — melee carries you to the endgame, firepower carries you through it."]
			icon: {
				Count: 1
				id: "tacz:modern_kinetic_gun"
				tag: {
					GunId: "tacz:ak47"
				}
			}
			id: "5C5C000000000001"
