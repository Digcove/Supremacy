		}
		{
			dependencies: ["0976ED57329E13EB"]
			description: ["Mystical Agriculture adds crop-form resource generation — seeds that grow essence, which converts to any base material in the game. Inferium Essence is the foundation tier: harvest it from Inferium Crops planted on any farmland type. Four Inferium Essence craft into one Prudentium (T2). Ten Inferium Essence make one T1 resource seed for a target material. Build an Inferium crop row as your base passive resource loop — it replaces mining for common materials given sufficient time and Growth Accelerators."]
			id: "714F00CC06EC123C"
			rewards: [{
				count: 3
				id: "2564A0894670BC9E"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [{
				count: 10L
				id: "4548C96B774D87A5"
				item: "mysticalagriculture:inferium_essence"
				type: "item"
			}]
			title: "Inferium Essence"
			x: -3.5d
			y: -5.0d
		}
		{
			description: ["Mystical Agriculture resource seeds grow specific material essence in crop form. Iron Seeds produce Iron Essence. Stone Seeds produce Stone Essence. Each seed requires Inferium Essence plus the target material in crafting, and must be grown on Mystical Soil — crafted from Inferium Essence and Soul Sand. Essence converts to the target material in the crafting table at 1:1 ratio. This is how you produce unlimited iron and stone without a mining trip. T1 seeds cover basic materials; higher tiers unlock rare ores once Prudentium Essence is available."]
			id: "00A942F8214A3072"
			rewards: [{
				count: 3
				id: "5FD1AFEB0B520457"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [{
				id: "288BAC952C87EAB2"
				item: "mysticalagriculture:inferium_seeds"
				type: "item"
			}]
			title: "Resource Seeds"
			x: -1.0d
			y: -5.0d
		}
		{
			description: ["The Growth Accelerator is placed directly under Mystical Soil and adds a growth tick probability to the crop above. Multiple Accelerators stack — up to 64 in a column beneath a single plot, each adding another layer of probability. At ten Accelerators per plot, harvest intervals drop to seconds. Automate the harvest with a Create Mechanical Harvester or a Farmer's Delight Farming Station to complete the cycle without player input. Build Accelerators before planting your main resource seed rows; the speed difference is immediate."]
			id: "2E2F4D4734C41151"
			rewards: [{
				count: 3
				id: "5A82462077A4D6A1"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [{
				id: "4FCF065BE6F7C0C5"
				item: "mysticalagriculture:growth_accelerator"
				type: "item"
			}]
			title: "Growth Accelerator"
			x: 1.5d
			y: -5.0d
		}
		{
			description: ["Prudentium Essence is Mystical Agriculture's T2 tier — crafted from four Inferium Essence, it gates Iron, Gold, Diamond, and Redstone resource seeds. It also converts to Mystical Fertilizer, which instantly matures any Mystical Agri crop to harvestable state. Reaching T2 means your farm can passively produce every standard ore type in the game. GregTech's ore processing chain exists to multiply that output — the Macerator's byproduct dusts apply to farm-grown ore essence just as to mined ore. Feed your Macerators with Mystical Agriculture output."]
			id: "1518C1146C48D5BB"
			rewards: [{
				count: 5
				id: "63934B9BABE0981A"
				item: "kubejs:coin"
