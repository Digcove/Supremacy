		}
		{
			dependencies: [
				"1A2B3C4D00000020"
				"1A2B3C4D00000008"
			]
			description: ["The Essence Replicator converts higher-tier essence downward — or replicates specific essence types into bulk output given sufficient EU input. At HV power, a single Replicator fed Supremium can produce targeted material essences at rates that replace multiple specialized crop rows. This is the inflection point where the MA farm transitions from gardening to manufacturing — input one tier, output another in bulk, with power as the only variable cost."]
			id: "1A2B3C4D00000021"
			rewards: [{
				count: 8
				id: "3A2B3C4D00000021"
