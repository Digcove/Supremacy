				}
				title: "Any Mystical Greenhouse"
				type: "item"
			}]
			title: "Mystical Greenhouse"
			x: 16.0d
			y: -3.0d
		}
		{
			dependencies: ["1A2B3C4D0000001F"]
			description: ["The GTCEu Essence Burner consumes MA essence to generate EU — turning surplus crop output into power. Lower-tier essences generate modest EU; higher tiers burn with significantly greater efficiency. At Supremium burn rates it competes with mid-tier GTCEu generators. Pair with the Greenhouse: excess output generates power, power feeds Greenhouses, Greenhouses produce more excess. The loop runs itself once established and gives your farm a reason to overproduce."]
			id: "1A2B3C4D00000020"
			rewards: [{
				count: 5
				id: "3A2B3C4D00000020"
				item: "kubejs:coin"
