		{
			dependencies: ["1A2B3C4D00000004"]
			description: ["The GTCEu Mystical Greenhouse accelerates MA crop growth through voltage-based tick injection — more EU/t in, faster crop cycles. Unlike stacked Growth Accelerators, the Greenhouse effect scales with EU tier rather than block count, so a single HV Greenhouse replaces dozens of Accelerators. Build it adjacent to your crop rows and connect it to your power network. This is the first industrial integration between GTCEu and the farm, and the cheapest throughput multiplier available at LV."]
			id: "1A2B3C4D0000001F"
			rewards: [{
				count: 5
				id: "3A2B3C4D0000001F"
				item: "kubejs:coin"
				type: "item"
			}]
			shape: "rsquare"
			tasks: [{
				id: "2A2B3C4D0000001F"
				item: {
					Count: 1
					id: "itemfilters:or"
					tag: {
						items: [
