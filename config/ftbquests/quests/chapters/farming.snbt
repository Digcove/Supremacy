		{
			dependencies: ["1518C1146C48D5BB"]
			description: ["Mystical Agriculture extends crop farming beyond food — every ore, gem, and rare material in the game can be grown in soil given the right seed and the right essence tier. Inferium and Prudentium gave you a foothold. The tiers above — Tertium, Imperium, Supremium, Awakened Supremium, and Insanium — each unlock a new class of resource seeds, each guarded by a deeper magical requirement. The farm does not advance on its own. Your soul cultivation and magical mastery set the ceiling. Grow deeper."]
			id: "1A2B3C4D00000001"
			tasks: [{
				id: "2A2B3C4D00000001"
				title: "The Essence of All Things"
				type: "checkmark"
			}]
			title: "The Essence of All Things"
			x: 7.0d
			y: -5.0d
		}
		{
			dependencies: [
				"1A2B3C4D00000001"
				"5FC6C2D842B38AD2"
				"6CD3FDD027906C44"
			]
			description: ["Tertium Essence is not merely a crafting upgrade — it requires the ambient magical field of an active soul ring bond and a functional mana generation system. The soul ring creates a spiritual resonance field around your cultivation base; the Botania mana pool grounds that field into physical mana flux. Together they stabilize the essence matrix required for Tier 3 crop growth. A single Endoflame or Hydroangeas setup is sufficient — what matters is that the mana loop is active and your first soul ring is bound."]
			id: "1A2B3C4D00000002"
			tasks: [{
				id: "2A2B3C4D00000002"
				title: "Soul and Mana Converge"
				type: "checkmark"
