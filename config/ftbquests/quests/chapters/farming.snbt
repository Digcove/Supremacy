			title: "Crop Diversity"
			x: -3.5d
			y: 0.0d
		}
		{
			description: ["The Cooking Pot accepts up to four ingredients plus water and produces multiple servings in one operation — no crafting table required. Place it over any heat source (campfire, fire, magma block) and right-click the output slot with an empty bowl to collect each serving. A single craft typically produces four to six servings. Higher-complexity recipes provide lasting food buffs and higher saturation than anything vanilla Minecraft can produce. The Cooking Pot is the reason food stops being a maintenance task and starts being a force multiplier for combat."]
			id: "6F671427EEE910E5"
			rewards: [{
				count: 3
				id: "0E503D19B9DFAEEE"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [{
				id: "407A6E1B01A7DC6C"
				item: "farmersdelight:cooking_pot"
				type: "item"
			}]
			title: "Cooking Pot"
			x: -1.0d
			y: 0.0d
		}
		{
			description: ["Vegetable Soup requires carrots, potatoes, Pam's cabbage, and water in the Cooking Pot. It provides six hunger bars and a short Regeneration effect — enough to replace cooked pork chops as your expedition food. Cook it in batches of six servings and stock your inventory before heading into Mine & Slash combat. At higher cultivation ranks, food buff stacking with Soul Land cultivation bonuses and M&S stat soul investments creates a meaningful composite effect that individual hunger values obscure. Feed yourself properly before every serious encounter."]
			id: "1F736DBC0CBACE22"
			rewards: [{
				count: 3
				id: "04C90741D644311F"
				item: "kubejs:coin"
				type: "item"
			}]
			tasks: [{
				id: "3E0754F01CC8368B"
				item: "farmersdelight:vegetable_soup"
				type: "item"
			}]
			title: "Vegetable Soup"
			x: 1.5d
			y: 0.0d
		}
		{
			dependencies: ["0976ED57329E13EB"]
			description: ["With a diverse crop rotation, an active Cooking Pot, and real food in your inventory, the farm is established. A self-sustaining food loop removes hunger as a constraint on your playtime. The Mystical Agriculture path below extends this into passive resource generation — every ore, every essence material grown and harvested without a pickaxe. This is the base from which every expedition launches and to which it returns."]
			id: "55B11B56BC0C546D"
