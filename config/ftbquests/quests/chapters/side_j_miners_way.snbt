		icon: {id: "minecraft:emerald_ore", Count: 1b}
		description: ["Found exclusively in mountain biomes (Y=-16 to Y=320), usually as single-block deposits. Trade with villagers or use the Mystical Agriculture Emerald Seed for a steady supply."]
