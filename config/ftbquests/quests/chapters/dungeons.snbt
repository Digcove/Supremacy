		}
		{
			dependencies: ["DG01000000000005"]
			description: ["Inside Dungeon Realm maps, Harvest Portals occasionally spawn — entry points into The Harvest dimension. Inside, clearing the encounter yields Chaotic Gems, a special currency used in Orb Forge and Mine and Slash upgrade recipes. Harvest portals are uncommon and do not spawn in every map. When one appears, it is worth entering — Chaotic Gems are not obtainable through any other consistent source. Exit via the Library of Exile return block inside the Harvest room."]
			id: "DG01000000000006"
