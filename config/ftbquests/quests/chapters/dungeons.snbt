			y: -7.5d
		}
		{
			dependencies: ["DG01000000000004"]
			description: ["The Boss Teleporter block spawns somewhere inside the dungeon and links to the Boss Room. It does not appear on any map marker — finding it requires full exploration of the instance. The Boss Room hosts a level-scaled map boss with elevated stats. Completing the boss opens the Reward Room, which drops gear, currency, and potentially a higher-tier Dungeon Map for your next run. Kill percentage at the moment of boss death determines Reward Room loot quality."]
			id: "DG01000000000005"
			rewards: [
