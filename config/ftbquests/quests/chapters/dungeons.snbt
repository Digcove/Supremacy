	quests: [
		{
			description: ["Map-based dungeons are the primary endgame content loop. Dungeon Realm provides instanced dungeons opened via a Map Device block — put a Dungeon Map in the device, enter the instance, kill mobs to raise your kill percentage, find the Boss Teleporter, and clear the boss for the Reward Room. Library of Exile adds a separate portal-based atlas system with its own map pool and boss rotation. Ancient Obelisks add wave-based encounters directly in the overworld with no separate dimension. All three systems use Mine and Slash scaling — mobs match your character level and roll affixes that shift the difficulty and loot ceiling."]
			id: "DG01000000000001"
			rewards: [
				{
					auto: "enabled"
					command: "/mine_and_slash give xp_times_lvl @p 100"
					elevate_perms: true
