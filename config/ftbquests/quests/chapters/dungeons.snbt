			y: -12.5d
		}
		{
			dependencies: ["DG01000000000005"]
			description: ["Bosses in Legendary (Tier 61–80) and Mythic (Tier 81–100) maps have a chance to drop Uber Fragments. Combining fragments produces a Dungeon Map Uber Upgrade. Apply this to any map to convert it into an Uber Map — an encounter against a greatly empowered version of a campaign boss. Uber Bosses drop Unique Jewels and endgame gear not obtainable anywhere else in the Dungeon Realm system. Reaching Legendary tier maps is the prerequisite; the Uber system is the endgame beyond it."]
			id: "DG01000000000007"
