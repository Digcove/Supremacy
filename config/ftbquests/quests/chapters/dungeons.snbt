		}
		{
			dependencies: ["DG01000000000002"]
			description: ["The Map Device is a placeable block that accepts Dungeon Maps. Place it down, then right-click it with a Dungeon Map to enter the instanced dungeon. The Home Pearl is a consumable that teleports you back to the overworld location where you entered the map. Always carry Home Pearls before entering a map — dying inside removes your map entry tag, and without a Home Pearl or a return teleporter block, you lose your position. Craft both before attempting your first map run."]
			id: "DG01000000000003"
			rewards: [
				{
					auto: "enabled"
