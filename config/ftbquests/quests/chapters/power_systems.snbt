			]
			title: "Cables and Transformers"
			x: 8.0d
			y: -4.0d
		}
		{
			dependencies: ["PS01000000000021"]
			description: ["Battery Buffers store EU on the cable network and redistribute it to connected machines. Each Buffer holds a configurable number of batteries and charges or discharges them based on network demand. Use a 4A Battery Buffer as the minimum per machine cluster — it absorbs surge demand during machine startup and prevents the generator from spiking. Place the Buffer between the generator output and the machine input cluster; the generator charges the buffer, the buffer feeds the machines. Always build a Battery Buffer before the machine it serves or power spikes will damage lower-tier machines at startup."]
			id: "PS01000000000022"
			rewards: [{
				count: 2
				id: "PS03000000000022"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
			tasks: [{
				id: "PS02000000000038"
				item: "gtceu:lv_battery_buffer_4a"
				type: "item"
			}]
			title: "Battery Buffers"
			x: 8.0d
			y: -5.5d
		}
		{
			dependencies: ["PS01000000000022"]
			description: ["GTCEu Energy Converters bridge the EU and RF systems bidirectionally. Place an Energy Converter on a GTCEu cable and connect RF cables to its sides — it continuously converts EU to RF or RF to EU based on configuration. This is the primary method for powering Thermal Expansion machines from GTCEu generators, or for feeding EU into a GTCEu network from a Powah reactor or Compression Dynamo bank. The conversion rate is fixed per tier; use an HV Converter or higher for high-volume cross-system transfers. Flux Networks (see below) eliminates the need for long cable runs entirely once established."]
			id: "PS01000000000023"
			rewards: [{
				count: 2
				id: "PS03000000000023"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
