			y: -9.0d
		}
		{
			dependencies: ["PS01000000000019"]
			description: ["The GTCEu Nuclear Reactor burns enriched uranium fuel cells to produce EU — the highest single-structure EU output available before ZPM-tier machines. Fuel production requires uranium ore processing to oxide, reduction to metal, and enrichment in the Centrifuge. Spent fuel cells can be reprocessed for additional byproduct materials. The Nuclear Reactor operates at EV voltage; running it below EV capability wastes output. Build it when your uranium mine or Mystical Agriculture uranium seed supply is sufficient to sustain continuous fuel cell production. It is the natural capstone of the single-block generator progression."]
			id: "PS01000000000020"
			rewards: [{
				count: 3
				id: "PS03000000000020"
				item: "mmorpg:currency/mirror"
				type: "item"
