					type: "item"
				}
				{
					id: "PS02000000000024"
					item: "gtceu:hv_steam_turbine"
					type: "item"
				}
			]
			title: "Steam Turbines"
			x: 5.0d
			y: -4.5d
		}
		{
			dependencies: ["PS01000000000016"]
			description: ["GTCEu Gas Turbines burn Hydrogen, Natural Gas, and similar gaseous fuels. Hydrogen is the easiest early gas fuel — produced via Electrolyzer from water using any EU input. Natural Gas is extracted from oil wells or chemical synthesis. At LV, a single Gas Turbine on Hydrogen produces EU at a higher EU/t ratio than the equivalent Steam Turbine, making it the preferred single-block generator once electrolysis is running. Upgrade through MV and HV Gas Turbines as your electrolysis array scales; HV Gas Turbines on high-density gas fuels are competitive with mid-tier multiblock output."]
			id: "PS01000000000017"
			rewards: [{
				count: 2
				id: "PS03000000000017"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
			tasks: [
				{
