			}]
			title: "Nuclear Reactor"
			x: 5.0d
			y: -10.5d
		}
		{
			dependencies: ["PS01000000000015"]
			description: ["GTCEu cables carry EU between generators and machines. Each cable tier carries a maximum voltage and a maximum amperage; mismatch above the cable's voltage rating causes explosion, so always match cable tier to machine tier. Rubber (LV), Tin (LV), Copper (LV-MV), Aluminium (MV-HV), and Tungsten (HV-EV) are the primary cable materials. Long cable runs lose EU per block — use Energy Hatches or Transformers to boost signals over distance. The Transformer block steps voltage up or down between tiers, allowing a single HV generator to feed both HV machines and a lower-voltage secondary network."]
			id: "PS01000000000021"
			rewards: [{
				count: 2
				id: "PS03000000000021"
				item: "mmorpg:currency/mirror"
				type: "item"
			}]
			tasks: [
				{
					id: "PS02000000000035"
					item: "gtceu:rubber_cable_1x"
					type: "item"
