	}, {
		id: "0000000000014018"
		x: 2.0d
		y: -2.0d
		dependencies: ["0000000000014001"]
		title: "Hull and Balloon"
		icon: {id: "eureka:balloon", Count: 1b}
		description: ["Eureka Ships runs on Valkyrien Skies — a physics engine that lets built structures become moving entities. Any block structure can become a ship. Place a Ship Helm on it, right-click to assemble it into a physics object, and it detaches from the world.", "Balloons make it fly. Without them, the ship is a boat — surface-bound, physics-correct, useless for what you actually want. Add Balloons to the structure before assembling. Add Engines for horizontal thrust. The Anchor is what brings you back down cleanly. Check JEI for all three recipes.", "This is the craft track. The airship exists in parallel with the Aether — both are sky, approached differently. One dimension you explore on foot. The other you build to carry everything."]
		tasks: [{
			id: "0000000000014019"
			type: "item"
			item: {id: "eureka:ship_helm", Count: 1b}
		}, {
			id: "000000000001401A"
			type: "item"
			item: {id: "eureka:balloon", Count: 1b}
		}]
		rewards: [{
			id: "000000000001401B"
			type: "item"
			item: {id: "minecraft:oak_planks", Count: 64b}
		}]
	}, {
		id: "000000000001401C"
		x: 4.0d
		y: -2.0d
		dependencies: ["0000000000014018"]
		title: "Sky Captain"
		icon: {id: "eureka:ship_helm", Count: 1b}
		description: ["Build any structure you want. It doesn't have to be large. It doesn't have to be symmetrical. It has to have a Helm and at least one Balloon.", "Right-click the Helm to assemble. The physics engine takes over. Use the Helm to ascend and descend. Use Engines for forward movement. Use the Anchor to land cleanly.", "The sky is yours now. Everything that follows — the Aether, the space tier, the endgame dimensions — you reach from up here."]
		tasks: [{
			id: "000000000001401D"
			type: "checkmark"
			title: "Assemble a ship with Balloons and fly it into the open sky"
		}]
