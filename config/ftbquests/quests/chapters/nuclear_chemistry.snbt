			]
		}
		{
			title: "Industrial Chemistry"
			icon: "gtceu:large_chemical_reactor"
			x: -4d
			y: 3d
			description: ["GTCEu's multiblock chemistry machines handle industrial-scale throughput that single-block machines cannot match. The Large Chemical Reactor processes chemical reactions simultaneously across internal coil layers; the Large Electrolyzer and Large Centrifuge do the same for their processes. These multiblocks typically use Invar and Stainless Steel casings with Cupronickel heating coils — building them marks the transition from workshop chemistry to factory-scale chemical engineering capable of supporting your nuclear program."]
			dependencies: ["NC01000000000006"]
			id: "NC01000000000007"
			tasks: [
				{
					id: "NC02000000000008"
