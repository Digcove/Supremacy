			]
		}
		{
			title: "Fissile Material"
			icon: "gtceu:uranium_dust"
			x: 4d
			y: -3d
			description: ["Natural uranium consists of about 99.3% U-238 and 0.7% U-235. Only U-235 sustains the fission chain reaction required for reactor fuel. GTCEu models enrichment accurately: ore is crushed and processed through the standard ore-to-dust chain, then the Large Centrifuge separates U-235 from U-238 based on the slight mass difference between isotopes. You need industrial chemistry infrastructure — specifically the Large Centrifuge — before you can produce U-235 in meaningful quantities. This is by design."]
			dependencies: ["NC01000000000007"]
			id: "NC01000000000016"
			tasks: [
				{
					id: "NC02000000000021"
					type: "item"
					item: "gtceu:uranium_dust"
				}
				{
					id: "NC02000000000022"
					type: "item"
					item: "gtceu:uranium_235_dust"
				}
			]
			rewards: [
				{
					id: "NC03000000000016"
					type: "item"
					item: "mmorpg:currency/mirror"
					count: 2
				}
			]
		}
		{
			title: "Hexafluoride Enrichment"
			icon: "gtceu:uranium_hexafluoride_bucket"
			x: 4d
			y: -2d
			description: ["Before enrichment can scale, uranium is converted to gaseous Uranium Hexafluoride (UF6) by reacting uranium dust with Fluorine in the Chemical Reactor. UF6 flows through the Large Centrifuge, where the tiny mass difference between U235-F6 and U238-F6 molecules allows cascaded separation. Enriched UF6 contains higher U-235 concentration; the depleted stream is stored or discarded. This process mirrors how real-world centrifuge enrichment plants operate and consumes significant chemical reactor throughput to run continuously."]
			dependencies: ["NC01000000000016"]
			id: "NC01000000000017"
			tasks: [
				{
					id: "NC02000000000023"
					type: "item"
					item: "gtceu:uranium_hexafluoride_bucket"
				}
				{
					id: "NC02000000000024"
					type: "item"
					item: "gtceu:enriched_uranium_hexafluoride_bucket"
				}
			]
			rewards: [
				{
					id: "NC03000000000017"
					type: "item"
					item: "mmorpg:currency/mirror"
					count: 2
				}
			]
		}
		{
			title: "Fuel Rod Assembly"
			icon: "kubejs:leu238_fuel_rod"
			x: 4d
			y: -1d
			description: ["Enriched UF6 is converted back to uranium oxide, pressed into fuel pellets, and assembled into fuel rods. LEU-238 fuel rods — Low Enriched Uranium with a U-238 cladding — are the standard GTCEu reactor fuel. Each rod contains multiple pellets sealed in zircaloy cladding to prevent fission products from entering the coolant loop. Assembly requires a Chemical Reactor and an Assembling Machine working in sequence. Produce at least four rods before building the reactor, as the machine expects a full core load before it will sustain criticality."]
			dependencies: ["NC01000000000017"]
			id: "NC01000000000018"
			tasks: [{
				id: "NC02000000000025"
				type: "item"
				item: "kubejs:leu238_fuel_rod"
			}]
			rewards: [
				{
					id: "NC03000000000018"
					type: "item"
					item: "mmorpg:currency/mirror"
					count: 2
				}
			]
		}
		{
			title: "Critical Mass"
			icon: "gtceu:nuclear_reactor"
			x: 4d
			y: 0d
			description: ["The GTCEu Nuclear Reactor is a large multiblock structure that sustains a controlled fission chain reaction to generate enormous EU output. Fuel rods are loaded into the reactor core and consumed over time as fission proceeds. The reactor requires a coolant loop — distilled water at minimum, higher-grade coolants for better efficiency — and a proper casing structure of Lead or Tungstensteel to contain radiation. A correctly fueled and cooled reactor generates more power than any combustion generator in the pack and requires minimal oversight until the rods are spent."]
			dependencies: ["NC01000000000018"]
			id: "NC01000000000019"
			tasks: [{
				id: "NC02000000000026"
				type: "item"
				item: "gtceu:nuclear_reactor"
			}]
			rewards: [
				{
					id: "NC03000000000019"
					type: "item"
					item: "mmorpg:currency/mirror"
					count: 2
				}
			]
		}
		{
			title: "Spent Fuel Reprocessing"
			icon: "gtceu:depleted_uranium_hexafluoride_bucket"
			x: 4d
			y: 1d
			description: ["Spent fuel rods are not waste — they are feedstock for the next stage of the nuclear cycle. Dissolve the spent rods in chemical baths, centrifuge the resulting solution, and separate the isotope fractions by chemical reactivity. Depleted UF6 can be re-enriched. More valuably, spent uranium fuel produces Plutonium-239 through neutron capture and beta decay during reactor operation. Plutonium is recovered by chemical reprocessing of the dissolved spent fuel. This closes the fuel cycle and provides material for significantly higher-yield rods."]
			dependencies: ["NC01000000000019"]
			id: "NC01000000000020"
			tasks: [
				{
					id: "NC02000000000027"
					type: "item"
					item: "gtceu:depleted_uranium_hexafluoride_bucket"
				}
				{
					id: "NC02000000000028"
					type: "item"
					item: "gtceu:plutonium_dust"
					optional: true
				}
			]
			rewards: [
