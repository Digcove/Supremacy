			]
		}
		{
			title: "Black Gold"
			icon: "gtceu:oil_bucket"
			x: -1d
			y: -4d
			description: ["Crude oil is a complex mixture of hydrocarbons that GTCEu refines into fuels, chemical feedstocks, and lubricants. Oil deposits generate underground and can be pumped continuously with the GTCEu Pump or extracted by right-clicking with empty buckets. Heavy oil, light oil, and natural gas variants each have different compositions and different refining pathways. Getting a reliable oil supply early is worth the effort — petroleum fuels are the most energy-dense inputs to GTCEu combustion generators and pay off rapidly."]
			dependencies: ["NC01000000000001"]
			id: "NC01000000000008"
			tasks: [{
				id: "NC02000000000011"
				type: "item"
				item: "gtceu:oil_bucket"
			}]
			rewards: [
				{
					id: "NC03000000000008"
					type: "item"
					item: "mmorpg:currency/mirror"
					count: 2
				}
			]
		}
		{
			title: "Fractional Distillation"
			icon: "gtceu:distillation_tower"
			x: -1d
			y: -3d
			description: ["The Distillation Tower is the core multiblock of the oil refinery chain. It separates crude oil into fractions by boiling point: heavy fuel oil, naphtha, light fuel oil, sulfuric compounds, and gases all emerge from different output hatches arranged by height. The tower requires a steel or titanium casing structure with multiple output fluid hatches — each hatch height corresponds to a different boiling fraction. One Distillation Tower fed by a steady pump produces all downstream fuel inputs simultaneously."]
			dependencies: ["NC01000000000008"]
			id: "NC01000000000009"
			tasks: [{
				id: "NC02000000000012"
				type: "item"
				item: "gtceu:distillation_tower"
			}]
			rewards: [
				{
					id: "NC03000000000009"
					type: "item"
					item: "mmorpg:currency/mirror"
					count: 2
				}
			]
		}
		{
			title: "Heavy Fractions"
			icon: "gtceu:naphtha_bucket"
			x: -1d
			y: -2d
			description: ["The Distillation Tower outputs multiple fractions simultaneously. Naphtha is the light fraction used as chemical feedstock and gasoline precursor. Heavy oil and light fuel oil are energy-dense combustion fuels at different grades. Sulfurous fractions — sulfuric naphtha, sulfuric light fuel oil — must be de-sulfurized by the Cracker before they reach maximum energy density. Route each fraction appropriately: feedstocks to reactors, combustibles to engines, and heavy residuals to the cracker."]
			dependencies: ["NC01000000000009"]
			id: "NC01000000000010"
			tasks: [
				{
					id: "NC02000000000013"
					type: "item"
					item: "gtceu:naphtha_bucket"
				}
				{
					id: "NC02000000000014"
