					type: "item"
					item: "mmorpg:currency/mirror"
					count: 2
				}
			]
		}
		{
			title: "Plutonium Economy"
			icon: "kubejs:plu_fuel_rod"
			x: 4d
			y: 2d
			description: ["Plutonium-239 fuel rods provide substantially higher energy output than LEU-238 rods — the same reactor runs hotter and longer per rod loaded. MOX (Mixed Oxide) rods blend plutonium with uranium to manage the higher reactivity, extending fuel lifetime while maintaining elevated output. The plutonium fuel cycle requires more advanced chemical processing to handle reprocessed materials, but the payoff in sustained power output makes it the standard endgame reactor fuel and the entry point for the full nuclear material ladder that feeds into Americium and Curium."]
			dependencies: ["NC01000000000020"]
			id: "NC01000000000021"
			tasks: [{
				id: "NC02000000000029"
				type: "item"
				item: "kubejs:plu_fuel_rod"
