					item: "gtceu:oil_heavy_bucket"
					optional: true
				}
			]
			rewards: [
				{
					id: "NC03000000000010"
					type: "item"
					item: "mmorpg:currency/mirror"
					count: 2
				}
			]
		}
		{
			title: "Catalytic Cracking"
			icon: "gtceu:cracker"
			x: -1d
			y: -1d
			description: ["The GTCEu Cracker applies steam or hydrogen at high temperature and pressure to break large hydrocarbon chains into smaller, more useful molecules. Steam-cracking produces light olefins and de-sulfurized fractions; hydrogen-cracking pushes further toward high-grade fuels and gasoline precursors. The Cracker is the bridge between raw distillation output and true petroleum products. It requires Stainless Steel casings and Cupronickel heating coils, and connects directly to the Distillation Tower's heavy fraction outputs."]
			dependencies: ["NC01000000000010"]
			id: "NC01000000000011"
			tasks: [{
				id: "NC02000000000015"
				type: "item"
				item: "gtceu:cracker"
			}]
			rewards: [
				{
					id: "NC03000000000011"
					type: "item"
					item: "mmorpg:currency/mirror"
					count: 2
				}
			]
		}
		{
			title: "Green Chemistry"
			icon: "gtceu:bio_diesel_bucket"
			x: -1d
			y: 0d
			description: ["Bio-diesel is produced by reacting seed oil with methanol in the LV Chemical Reactor — no oil supply required. It has lower energy density than petroleum diesel but is a practical early combustion fuel while you establish a proper refinery. Bio-diesel also demonstrates the Chemical Reactor's fluid-in fluid-out workflow that the entire petroleum chain depends on. Pressing seeds into oil and reacting with methanol produced by biomass processing is a closed, renewable fuel loop viable from the early game."]
			dependencies: ["NC01000000000011"]
			id: "NC01000000000012"
			tasks: [{
				id: "NC02000000000016"
				type: "item"
				item: "gtceu:bio_diesel_bucket"
			}]
			rewards: [
				{
					id: "NC03000000000012"
					type: "item"
					item: "mmorpg:currency/mirror"
					count: 2
				}
			]
		}
		{
			title: "Refined Fuel"
			icon: "gtceu:diesel_bucket"
			x: -1d
			y: 1d
			description: ["Diesel is the standard petroleum fuel for GTCEu combustion engines. Produced from heavy fuel oil fractions through the refinery chain, diesel offers significantly more EU/t than bio-diesel in combustion generators and justifies the multiblock investment of the Distillation Tower. Diesel also unlocks the Large Combustion Engine, which processes fluid fuel at industrial throughput. Establish a diesel pipeline and your power requirements in the LV–HV tier are largely covered with minimal ongoing attention."]
			dependencies: ["NC01000000000012"]
			id: "NC01000000000013"
			tasks: [{
				id: "NC02000000000017"
				type: "item"
				item: "gtceu:diesel_bucket"
			}]
			rewards: [
