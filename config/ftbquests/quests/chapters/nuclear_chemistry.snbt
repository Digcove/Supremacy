	quests: [
		{
			title: "The Chemical Industry"
			icon: "gtceu:large_chemical_reactor"
			x: 0d
			y: 0d
			description: ["GTCEu's chemistry system is the backbone of advanced material production. Chemical Reactors combine two or more inputs into a product; Electrolyzers split compounds using electricity; Centrifuges separate mixtures by density; Chemical Baths coat or wash materials in reagents. Mastering these machines unlocks alloys, plastics, acids, and fuels that no other crafting system can produce. Oil refining and nuclear fuel processing are the apex of this chain."]
			dependencies: []
			id: "NC01000000000001"
			tasks: [{
				id: "NC02000000000001"
				type: "checkmark"
				title: "Enter the lab"
			}]
			rewards: [
				{
					id: "NC03000000000001"
					type: "item"
					item: "mmorpg:stone/1"
					count: 2
				}
			]
		}
		{
			title: "Reaction Chambers"
			icon: "gtceu:lv_chemical_reactor"
			x: -4d
			y: -3d
			description: ["The LV Chemical Reactor is the entry point to GTCEu's chemical processing chain. It takes two or more fluid or item inputs and produces a chemical product — plastics, acids, circuit components, dyes, and more. Nearly every advanced material in the tech tree passes through a Chemical Reactor at least once. Craft one early and keep it loaded; you will never stop using it."]
			dependencies: ["NC01000000000001"]
			id: "NC01000000000002"
			tasks: [{
				id: "NC02000000000002"
				type: "item"
				item: "gtceu:lv_chemical_reactor"
