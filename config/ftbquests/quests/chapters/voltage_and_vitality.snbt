			x: 3.0d
			y: 6.0d
		}

		{
			dependencies: ["BC01000000000002"]
			description: ["The Tier 5 Blood Altar requires 48 runes — including Dusk Runes that can only be crafted with significant LP expenditure — and reaches the highest operating state the altar can achieve. Tier 4 is an intermediate step: expand to 36 runes and craft the Master's Blood Orb before attempting the final expansion. At Tier 5 the altar can process the Archmage's Blood Orb, summon Demons for the Hellfire Forge, and produce the Living Armor components. The Tier 5 expansion is a significant resource investment; complete your Tier 4 rune ring first and let it accumulate LP before beginning the Dusk Rune phase."]
			id: "BC01000000000003"
			rewards: [{
				count: 5
				id: "DB01000000000003"
				item: "lightmanscurrency:coin_gold"
