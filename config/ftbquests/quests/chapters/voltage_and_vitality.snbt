				}
			]
			title: "Certus Quartz"
			x: 20.0d
			y: 0.0d
		}

		{
			dependencies: ["AE01000000000001"]
			description: ["Fluix Crystal is produced by simultaneously throwing Charged Certus Quartz, Redstone, and Nether Quartz into a body of water. All three must be thrown within a short window — the reaction is triggered by the combination, not by any one ingredient alone. Fluix is the core AE2 material: every cable type, formation core, annihilation core, and network component requires it. Grow Fluix in bulk using Crystal Growth Accelerators placed around a water source; the passive growth rate is too slow to meet the demand of a full network build."]
			id: "AE01000000000002"
			rewards: [{
				count: 4
				id: "AB01000000000002"
				item: "lightmanscurrency:coin_gold"
				type: "item"
			}]
			tasks: [{
				count: 8L
