				item: "gtceu:ev_electric_motor"
				type: "item"
			}]
			title: "EV Electric Motor"
			x: 6.0d
			y: 0.0d
		}

		{
			dependencies: ["EE01000000000001"]
			description: ["Nichrome is an iron-nickel-chromium alloy that sustains higher operating temperatures than Kanthal. Alloy Nickel and Chrome in the Alloy Smelter to produce Nichrome Ingots — the Chrome pipeline from your MV Electrolyzer already feeds this step. Draw the ingots through the Wiremill to produce Nichrome Double Wire. The EBF's Kanthal coil ring has taken you as far as 2700K. Nichrome raises that ceiling to 3300K — the threshold required to process Tungsten and begin the alloy chains beyond it."]
			id: "EE01000000000004"
			rewards: [{
				count: 3
				id: "EA01000000000003"
				item: "lightmanscurrency:coin_gold"
				type: "item"
			}]
			tasks: [
				{
					count: 4L
