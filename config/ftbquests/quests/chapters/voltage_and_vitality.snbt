			}]
			title: "Fluix Crystal"
			x: 23.0d
			y: 0.0d
		}

		{
			dependencies: ["AE01000000000002"]
			description: ["The Inscriber is a powered machine that prints processor circuits onto silicon wafers and assembles them into finished processors. It accepts a press in the top slot, a blank silicon wafer in the middle, and the metal foil in the bottom. Three presses exist: Logic, Calculation, and Engineering — each found rarely in Mysterious Cube loot or craftable through GTCEu's silicon processing chain. Set up at least three Inscribers running in parallel before attempting processor production at volume; each machine handles only one print at a time, and processors are consumed in stacks during network construction."]
			id: "AE01000000000003"
			rewards: [{
				count: 4
				id: "AB01000000000003"
				item: "lightmanscurrency:coin_gold"
				type: "item"
			}]
			tasks: [
