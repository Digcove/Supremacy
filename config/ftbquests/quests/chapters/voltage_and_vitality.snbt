				type: "item"
			}]
			title: "EV Machine Hull"
			x: 3.0d
			y: 0.0d
		}

		{
			dependencies: ["EE01000000000002"]
			description: ["The EV Electric Motor operates at higher current density than its MV counterpart — the coil windings are finer, the core is denser, and the heat tolerance demands Tungstensteel components. It is the base prerequisite for every EV machine. Build several before beginning the EV machine floor; the EV Piston, EV Robot Arm, EV Conveyor, and EV Pump all require one each, and they are all required before any EV machine can be assembled."]
			id: "EE01000000000003"
			rewards: [{
				count: 4
				id: "EA01000000000002"
				item: "lightmanscurrency:coin_gold"
				type: "item"
			}]
			tasks: [{
