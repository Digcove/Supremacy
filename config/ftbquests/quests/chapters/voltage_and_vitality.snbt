		}

		{
			dependencies: ["AE01000000000004"]
			description: ["The ME Controller is the brain of the Applied Energistics 2 network — every cable, drive, bus, and terminal operates by being topologically connected to one. It requires Terrasteel Plates from Botania's endgame and Titanium Plates from GTCEu in addition to processors and Fluix Steel; this is the hard convergence point that gates AE2 behind two separate progression threads. If you haven't completed Terrasteel production, do that now. Once the Controller is placed and powered, the entire network comes online simultaneously — drives, terminals, and buses all activate the moment they trace a path back to it."]
			id: "AE01000000000005"
			rewards: [{
				count: 8
				id: "AB01000000000005"
				item: "lightmanscurrency:coin_gold"
				type: "item"
			}]
			shape: "gear"
