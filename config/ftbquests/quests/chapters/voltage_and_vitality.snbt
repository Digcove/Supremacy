			x: 9.0d
			y: 0.0d
		}

		{
			dependencies: ["EE01000000000006"]
			description: ["Tungstensteel is the primary structural metal of EV and early IV construction. Alloy Tungsten Ingots with Steel in the EBF to produce it — the process runs comfortably within Nichrome coil range. Tungstensteel Plates, Rods, and Pipes form the internal framing of every EV machine and appear throughout the IV machine hull recipe. Begin producing it in continuous quantity now; Tungstensteel demand never decreases from this tier forward."]
			id: "EE01000000000007"
