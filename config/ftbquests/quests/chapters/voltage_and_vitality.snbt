		{
			dependencies: ["EE01000000000008"]
			description: ["Certus Quartz grows in crystalline clusters underground, most commonly in drier biomes and exposed stone. It is the base material of Applied Energistics 2 — every component from cable to controller derives from it. To charge raw Certus Quartz into its active form, build a Quartz Charger and run it on RF or FE power. Charged Certus Quartz grows slowly in water when placed adjacent to Crystal Growth Accelerators; automate this production line early, as demand for it is immediate and sustained throughout the AE2 build-out."]
			id: "AE01000000000001"
			rewards: [{
				count: 3
				id: "AB01000000000001"
				item: "lightmanscurrency:coin_gold"
				type: "item"
			}]
			tasks: [
