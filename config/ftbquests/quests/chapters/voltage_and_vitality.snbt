		{
			dependencies: ["5F36072A0F88C16F"]
			description: ["Three convergences. The Ur-Ghast Trophy from the Dark Tower and the Titanium Plates from the Electric Blast Furnace meet in the EV Machine Hull — the first machine chassis that operates at a voltage your earlier infrastructure couldn't sustain. In parallel, Certus Quartz grows in your world's caves, waiting to become the nervous system of a digital storage network. And the Blood Altar in your base, fed by your own life, is ready to ascend beyond the primitive structure you first built. Each thread runs at its own pace. All three must close before the next horizon opens."]
			id: "EE01000000000001"
			tasks: [{
				id: "EC01000000000001"
				title: "Enter Extreme Voltage"
				type: "checkmark"
			}]
			title: "Voltage and Vitality"
			x: 0.0d
			y: 0.0d
		}

		{
			dependencies: ["EE01000000000001"]
			description: ["The EV Machine Hull integrates a Twilight Forest Ur-Ghast Trophy into the bus structure — its resonant frequency stabilizes the high-voltage differential across the casing under continuous load. Nine Titanium Plates form the outer skin; the Trophy and Tungstensteel internal framing handle the EV current. Unlike LV and MV hulls, this chassis is expensive to produce in quantity — plan your Titanium output before committing to a full EV machine floor."]
			id: "EE01000000000002"
			rewards: [{
				count: 6
				id: "EA01000000000001"
				item: "lightmanscurrency:coin_gold"
				type: "item"
			}]
			shape: "gear"
