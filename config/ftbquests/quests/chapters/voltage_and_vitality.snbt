			}]
			title: "ME Controller"
			x: 32.0d
			y: 0.0d
		}

		{
			dependencies: ["AE01000000000005"]
			description: ["The ME Drive holds up to ten storage cells. Each cell stores thousands of items by type — a 1k Cell holds 1,024 item types in any quantity; a 64k Cell holds up to 65,536. Cells are inserted into the Drive, which connects to the network via AE2 cable and routes all stored items through the Controller to every connected Terminal. The ME Terminal provides a unified search interface over every item in the entire network — once active, it replaces every chest in your base. Build four or more Drives before moving storage in; running out of cell slots mid-migration interrupts network access."]
			id: "AE01000000000006"
			rewards: [{
				count: 5
