		}

		{
			dependencies: ["AE01000000000006"]
			description: ["Autocrafting delegates on-demand crafting to the network itself. Encode a recipe into a Blank Pattern at the Pattern Encoding Terminal, insert it into a Pattern Provider connected to the target machine or crafting table, then request the output from any ME Terminal. The network pulls ingredients from storage, routes them to the machine, and deposits the output automatically. Construct a Crafting CPU multiblock — at minimum one Crafting Unit and one Crafting Storage block — to handle job execution. Larger CPUs with more Crafting Storage handle longer, more recursive chains without stalling. Once autocrafting is online, you will never open a crafting table for a bulk recipe again."]
			id: "AE01000000000007"
			rewards: [{
				count: 8
				id: "AB01000000000007"
				item: "lightmanscurrency:coin_gold"
				type: "item"
			}]
			shape: "gear"
