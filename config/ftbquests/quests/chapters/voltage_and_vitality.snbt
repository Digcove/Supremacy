			title: "Autocrafting Online"
			x: 38.0d
			y: 0.0d
		}

		{
			dependencies: ["AE01000000000007"]
			description: ["GTCEu's ME Hatches and Buses integrate the ME network directly into GT multiblock machines. The ME Input Bus reads encoded patterns from the network and supplies ingredient items directly to the machine's input face without manual inventory management. The ME Output Bus deposits finished products back into the ME network. The ME Input Hatch and ME Output Hatch do the same for fluids. With these installed on your Macerator array, EBF, and Assembler, the autocrafting system can drive GT production lines end-to-end without intermediate chests. This is the point where your factory becomes fully autonomous."]
			id: "AE01000000000008"
			optional: true
